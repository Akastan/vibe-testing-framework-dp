      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření nové knihy"
        },
        {
          "name": "create_book_invalid_isbn",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoření knihy s neplatným ISBN"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
