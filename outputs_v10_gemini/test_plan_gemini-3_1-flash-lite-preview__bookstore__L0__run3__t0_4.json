          "expected_status": 200,
          "description": "Získání průměrného hodnocení knihy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_success",
