{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "health_check_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření dostupnosti API"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření nového autora s validními daty"
        },
        {
          "name": "create_author_invalid_data",
          "type": "error",
          "expected_status": 422,
          "description": "Pokus o vytvoření autora bez povinného jména"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_authors_default",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání seznamu autorů s výchozími parametry"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_author_not_found",
          "type": "error",
          "expected_status": 422,
          "description": "Pokus o získání neexistujícího autora"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření nové kategorie"
        }
      ]
    },
    {
      "endpoint": "/categories/{category_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_category_invalid_name",
