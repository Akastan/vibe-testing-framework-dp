        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_order_status_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Změna stavu objednávky na shipped"
        },
        {
          "name": "update_order_status_invalid",
