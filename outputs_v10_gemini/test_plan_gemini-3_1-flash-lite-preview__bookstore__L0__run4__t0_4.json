{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "check_api_health",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření, že API je dostupné"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_valid_author",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření autora s validními údaji"
        },
        {
          "name": "create_author_empty_name",
          "type": "error",
          "expected_status": 422,
          "description": "Pokus o vytvoření autora bez jména"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_authors_default",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání seznamu autorů s výchozími parametry"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_nonexistent_author",
          "type": "error",
          "expected_status": 422,
          "description": "Pokus o získání neexistujícího autora"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_invalid_isbn",
