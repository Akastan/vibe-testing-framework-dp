{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "check_api_health",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření, že API vrací 200 OK"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření nového autora"
        },
        {
          "name": "create_author_invalid_data",
          "type": "error",
          "expected_status": 422,
          "description": "Pokus o vytvoření autora bez jména"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Smazání autora, který má přiřazené knihy, vrací 409"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření knihy se stock 10"
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní ISBN vrací 409"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření stránkování knih"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_new_book_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na knihu vydanou v aktuálním roce vrací 400"
        },
        {
          "name": "apply_discount_valid_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Sleva na starší knihu proběhne úspěšně"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_positive_delta",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Přičtení skladu pomocí kladné hodnoty"
        },
        {
          "name": "update_stock_negative_result_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Odečtení více než je skladem vrací 400"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_to_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Přidání tagů ke knize"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tags_from_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Odebrání tagů z knihy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření recenze pro knihu"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_empty_reviews",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Kniha bez recenzí vrací null v průměrném hodnocení"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření kategorie"
        },
        {
          "name": "create_category_duplicate_name",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní název kategorie vrací 409"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření tagu"
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_assigned_tag_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Smazání tagu přiřazeného ke knize vrací 409"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Objednávka s nedostatkem skladu vrací 400"
        },
        {
          "name": "create_order_duplicate_book_id",
          "type": "error",
          "expected_status": 400,
          "description": "Duplicitní kniha v jedné objednávce vrací 400"
        },
        {
          "name": "create_order_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření objednávky"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_status_invalid_transition",
          "type": "error",
          "expected_status": 400,
          "description": "Nepovolený přechod stavu objednávky vrací 400"
        },
        {
          "name": "update_status_cancel_returns_stock",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Zrušení objednávky vrací sklad"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_confirmed_order_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Smazání potvrzené objednávky vrací 400"
        },
        {
          "name": "delete_pending_order_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání pending objednávky"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_book_cascades_reviews",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání knihy odstraní i recenze"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_nonexistent_author",
          "type": "error",
          "expected_status": 404,
          "description": "Neexistující autor vrací 404"
        }
      ]
    },
    {
      "endpoint": "/categories/{category_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_nonexistent_category",
          "type": "error",
          "expected_status": 404,
          "description": "Neexistující kategorie vrací 404"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_nonexistent_book",
          "type": "error",
          "expected_status": 404,
          "description": "Neexistující kniha vrací 404"
        }
      ]
    }
  ]
}