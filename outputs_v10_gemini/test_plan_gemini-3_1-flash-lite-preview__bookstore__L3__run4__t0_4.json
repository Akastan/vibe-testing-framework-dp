{
  "test_plan": [
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne vytvoreni autora"
        },
        {
          "name": "create_author_invalid_name",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba pri prazdnem jmenu"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Smazani autora s knihami vrací 409"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne vytvoreni kategorie"
        },
        {
          "name": "create_duplicate_category_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitni nazev kategorie vrací 409"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni knihy se stock=10"
        },
        {
          "name": "create_book_duplicate_isbn_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitni ISBN vrací 409"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_nonexistent_book_fails",
          "type": "error",
          "expected_status": 404,
          "description": "Neexistujici kniha vrací 404"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne vytvoreni recenze"
        },
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Rating mimo rozsah 1-5"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_no_reviews",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Kniha bez recenzi vraci null rating"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_old_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Sleva na starou knihu"
        },
        {
          "name": "apply_discount_new_book_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na knihu z aktualniho roku vrací 400"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_increase",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Navyseni skladu"
        },
        {
          "name": "update_stock_negative_result_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Odecet vetsi nez sklad vrací 400"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne vytvoreni tagu"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_to_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Pridani tagu ke knize"
        },
        {
          "name": "add_nonexistent_tag_fails",
          "type": "error",
          "expected_status": 404,
          "description": "Pridani neexistujiciho tagu vrací 404"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tags_from_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Odebrani tagu z knihy"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne vytvoreni objednavky"
        },
        {
          "name": "create_order_insufficient_stock_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Objednavka nad ramec skladu vrací 400"
        },
        {
          "name": "create_order_duplicate_book_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Duplicitni kniha v objednavce vrací 400"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_order_status_valid_transition",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Pending na Confirmed"
        },
        {
          "name": "update_order_status_invalid_transition",
          "type": "error",
          "expected_status": 400,
          "description": "Nemožny prechod stavu vrací 400"
        },
        {
          "name": "update_order_status_cancellation_restores_stock",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Zruseni objednavky vraci sklad"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_pending_order_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazani pending objednavky"
        },
        {
          "name": "delete_shipped_order_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Smazani odeslane objednavky vrací 400"
        }
      ]
    },
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "health_check_ok",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni dostupnosti API"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Strankovani knih"
        },
        {
          "name": "list_books_invalid_page",
          "type": "error",
          "expected_status": 422,
          "description": "Nevalidni stranka vrací 422"
        }
      ]
    }
  ]
}