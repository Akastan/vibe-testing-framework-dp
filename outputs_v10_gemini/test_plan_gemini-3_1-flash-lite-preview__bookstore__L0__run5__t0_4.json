    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_book_rating",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání průměrného hodnocení knihy."
        }
      ]
    },
    {
