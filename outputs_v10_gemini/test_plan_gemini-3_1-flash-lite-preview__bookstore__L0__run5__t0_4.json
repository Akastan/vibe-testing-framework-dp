          "description": "Ověření stránkování u výpisu knih."
        },
        {
          "name": "list_books_filter_price",
          "type": "edge_case",
          "expected_status": 200,
          "description": "Filtrování knih podle cenového rozpětí."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_book_detail",
