{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "check_api_health",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření, že API vrací status 200 pro health check."
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření nového autora s validními daty."
        },
        {
          "name": "create_author_invalid_data",
          "type": "error",
          "expected_status": 422,
          "description": "Pokus o vytvoření autora bez povinného jména."
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_authors_default",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání seznamu autorů s výchozími parametry."
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_author_by_id",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání detailu existujícího autora."
        },
        {
          "name": "get_author_nonexistent",
          "type": "error",
          "expected_status": 422,
          "description": "Pokus o získání autora s nevalidním ID."
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_author_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úspěšná aktualizace údajů autora."
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Úspěšné smazání autora."
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření nové kategorie."
        }
      ]
    },
    {
      "endpoint": "/books",
