      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Aplikace slevy na knihu."
        },
        {
          "name": "apply_discount_too_high",
          "type": "error",
