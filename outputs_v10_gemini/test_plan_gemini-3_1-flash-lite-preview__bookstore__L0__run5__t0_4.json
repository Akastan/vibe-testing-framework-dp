          "description": "Pokus o aplikaci slevy vyšší než 50 %."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_quantity",
