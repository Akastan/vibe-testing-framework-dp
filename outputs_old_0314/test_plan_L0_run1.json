{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "check_service_health",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni dostupnosti API"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_valid_author",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni noveho autora s validnimi daty"
        },
        {
          "name": "create_author_empty_name",
          "type": "error",
          "expected_status": 422,
          "description": "Pokus o vytvoreni autora s prazdnym jmenem"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_nonexistent_author",
          "type": "error",
          "expected_status": 422,
          "description": "Ziskani neexistujiciho autora"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_max_length_name",
          "type": "edge_case",
          "expected_status": 201,
          "description": "Vytvoreni kategorie s maximalni povolenou delkou nazvu"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_invalid_year",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoreni knihy s rokem vydani mimo rozsah"
        },
        {
          "name": "create_book_negative_price",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoreni knihy se zapornou cenou"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination_limits",
          "type": "edge_case",
          "expected_status": 200,
          "description": "Overeni strankovani s maximalni velikosti stranky"
        },
        {
          "name": "list_books_invalid_page",
          "type": "error",
          "expected_status": 422,
          "description": "Ziskani stranky mensi nez 1"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_book_invalid_isbn",
          "type": "error",
          "expected_status": 422,
          "description": "Aktualizace knihy s prilis kratkym ISBN"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Vlozeni recenze s hodnocenim mimo rozsah 1-5"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_valid_discount",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Aplikace validni slevy"
        },
        {
          "name": "apply_excessive_discount",
          "type": "error",
          "expected_status": 422,
          "description": "Pokus o slevu vyssi nez 50 procent"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_negative_quantity",
          "type": "error",
          "expected_status": 422,
          "description": "Aktualizace skladovych zasob na zaporne cislo"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_authors_default_params",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ziskani seznamu autoru s vychozimi parametry"
        }
      ]
    },
    {
      "endpoint": "/categories/{category_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_category_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Uspesne smazani kategorie"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_valid_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ziskani prumerneho hodnoceni knihy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_book_nonexistent",
          "type": "error",
          "expected_status": 422,
          "description": "Smazani neexistujici knihy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_reviews_empty_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ziskani seznamu recenzi pro knihu bez recenzi"
        }
      ]
    }
  ]
}