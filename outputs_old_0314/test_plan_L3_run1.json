{
  "test_plan": [
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_valid_author",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni noveho autora s validnimi udaji"
        },
        {
          "name": "create_author_with_duplicate_name_not_allowed",
          "type": "error",
          "expected_status": 409,
          "description": "Pokus o vytvoreni autora se jmenem, ktere jiz existuje"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_conflict",
          "type": "error",
          "expected_status": 409,
          "description": "Smazani autora, ktery ma prirazene knihy, musi vratit 409"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_with_duplicate_name",
          "type": "error",
          "expected_status": 409,
          "description": "Vytvoreni kategorie s duplicitnim nazvem"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_with_nonexistent_author",
          "type": "error",
          "expected_status": 404,
          "description": "Vytvoreni knihy s ID autora, ktery neexistuje"
        },
        {
          "name": "create_book_with_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Vytvoreni knihy s ISBN, ktere je jiz v systemu"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_with_invalid_page",
          "type": "error",
          "expected_status": 422,
          "description": "Strankovani se zaporny cislem strany"
        },
        {
          "name": "filter_books_by_price_range",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrace knih podle cenoveho rozpeti"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_invalid_rating_range",
          "type": "edge_case",
          "expected_status": 422,
          "description": "Vlozeni recenze s hodnocenim mimo rozsah 1-5"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_for_book_without_reviews",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni, ze vraceny rating je null, pokud kniha nema recenze"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_to_new_book_rejected",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na knihu vydanou pred mene nez rokem je zakazana"
        },
        {
          "name": "apply_discount_over_limit",
          "type": "edge_case",
          "expected_status": 422,
          "description": "Sleva vyssi nez 50 procent"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "reduce_stock_below_zero",
          "type": "error",
          "expected_status": 400,
          "description": "Snížení skladu pod nulu"
        },
        {
          "name": "increase_stock_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Uspesne navyseni skladu"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_nonexistent_author",
          "type": "error",
          "expected_status": 404,
          "description": "Cteni autora s ID, ktere neexistuje"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_book_invalid_year",
          "type": "edge_case",
          "expected_status": 422,
          "description": "Aktualizace roku vydani mimo povoleny rozsah"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_book_cascades_reviews",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazani knihy a overeni, ze se smazou i recenze"
        }
      ]
    },
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "health_check_status",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni dostupnosti API"
        }
      ]
    },
    {
      "endpoint": "/categories/{category_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_category_name_to_already_existing",
          "type": "error",
          "expected_status": 409,
          "description": "Prejmenovani kategorie na jmeno, ktere jiz existuje"
        }
      ]
    }
  ]
}