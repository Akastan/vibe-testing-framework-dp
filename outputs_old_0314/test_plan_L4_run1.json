{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "check_health_status",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni dostupnosti API"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne vytvoreni noveho autora"
        },
        {
          "name": "create_author_invalid_birth_year",
          "type": "error",
          "expected_status": 422,
          "description": "Pokus o vytvoreni autora s rokem narozeni mimo limit"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_duplicate_category_name",
          "type": "error",
          "expected_status": 409,
          "description": "Vytvoreni kategorie se jmenem, ktere jiz existuje"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_with_nonexistent_author",
          "type": "error",
          "expected_status": 404,
          "description": "Vytvoreni knihy s ID autora, ktery neexistuje"
        },
        {
          "name": "create_book_invalid_isbn_length",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoreni knihy s ISBN mimo rozsah 10-13 znaku"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination_boundaries",
          "type": "edge_case",
          "expected_status": 200,
          "description": "Overeni strankovani s parametry na hranici limitu"
        },
        {
          "name": "list_books_filter_by_price_range",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrace knih podle cenoveho rozpeti"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_book_cascade_reviews",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazani knihy a overeni kaskadoveho smazani recenzi"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoreni recenze s hodnocenim mimo rozsah 1-5"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_no_reviews",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni, ze prumerny rating je null pro knihu bez recenzi"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_max_allowed_discount",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Aplikace maximalni povolene slevy 50 procent"
        },
        {
          "name": "apply_discount_too_high",
          "type": "error",
          "expected_status": 422,
          "description": "Pokus o aplikaci slevy vyssi nez 50 procent"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_invalid_quantity",
          "type": "error",
          "expected_status": 400,
          "description": "Pokus o snizeni skladu pod nulu"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_linked_books",
          "type": "error",
          "expected_status": 409,
          "description": "Pokus o smazani autora, ktery ma prirazene knihy"
        }
      ]
    },
    {
      "endpoint": "/categories/{category_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_category_name_to_existing",
          "type": "error",
          "expected_status": 409,
          "description": "Prejmenovani kategorie na nazev, ktery jiz existuje"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_nonexistent_book",
          "type": "error",
          "expected_status": 404,
          "description": "Ziskani detailu knihy, ktera v DB neexistuje"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_zero_price",
          "type": "edge_case",
          "expected_status": 201,
          "description": "Vytvoreni knihy s cenou nula"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_invalid_page_number",
          "type": "error",
          "expected_status": 422,
          "description": "Strankovani se zaporny cislem strany"
        }
      ]
    }
  ]
}