{
  "test_plan": [
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni autora s validnimi daty"
        },
        {
          "name": "create_author_invalid_name",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoreni autora s prazdnym jmenem"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_author_etag_mismatch",
          "type": "error",
          "expected_status": 412,
          "description": "Aktualizace autora s neplatnym ETagem"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni knihy se vsemi povinnymi poli"
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Vytvoreni knihy s jiz existujicim ISBN"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni strankovani seznamu knih"
        },
        {
          "name": "list_books_filter_price",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrovani knih podle ceny"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_book_soft_deleted",
          "type": "edge_case",
          "expected_status": 410,
          "description": "Pokus o ziskani smazane knihy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_book_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Soft delete existujici knihy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/restore",
      "method": "POST",
      "test_cases": [
        {
          "name": "restore_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Obnoveni smazane knihy"
        },
        {
          "name": "restore_book_not_deleted",
          "type": "error",
          "expected_status": 400,
          "description": "Obnova knihy, ktera neni smazana"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Aplikace slevy na starsi knihu"
        },
        {
          "name": "apply_discount_too_new",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na knihu mladsi nez 1 rok"
        },
        {
          "name": "apply_discount_rate_limit",
          "type": "error",
          "expected_status": 429,
          "description": "Prekroceni limitu pro slevy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_insufficient",
          "type": "error",
          "expected_status": 400,
          "description": "Vyskladneni vice kusu nez je skladem"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/cover",
      "method": "POST",
      "test_cases": [
        {
          "name": "upload_cover_invalid_type",
          "type": "error",
          "expected_status": 415,
          "description": "Nahrani nepovoleneho typu souboru"
        },
        {
          "name": "upload_cover_too_large",
          "type": "error",
          "expected_status": 413,
          "description": "Nahrani souboru vetsiho nez 2MB"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Pridani recenze ke knize"
        },
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Pridani recenze s hodnocenim mimo rozsah 1-5"
        }
      ]
    },
    {
      "endpoint": "/books/bulk",
      "method": "POST",
      "test_cases": [
        {
          "name": "bulk_create_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Bulk vytvoreni bez API klice"
        },
        {
          "name": "bulk_create_partial_success",
          "type": "happy_path",
          "expected_status": 207,
          "description": "Castecny uspech pri hromadnem vytvoreni"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Objednavka knihy bez skladu"
        },
        {
          "name": "create_order_duplicate_items",
          "type": "error",
          "expected_status": 400,
          "description": "Duplicitni book_id v objednavce"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_status_invalid_transition",
          "type": "error",
          "expected_status": 400,
          "description": "Nepovoleny prechod stavu objednavky"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/invoice",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_invoice_forbidden",
          "type": "error",
          "expected_status": 403,
          "description": "Faktura pro pending objednavku"
        }
      ]
    },
    {
      "endpoint": "/exports/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_export_success",
          "type": "happy_path",
          "expected_status": 202,
          "description": "Spusteni asynchronniho exportu knih"
        }
      ]
    },
    {
      "endpoint": "/exports/{job_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_export_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Ziskani neexistujiciho exportu"
        }
      ]
    },
    {
      "endpoint": "/statistics/summary",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_statistics_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Ziskani statistik bez API klice"
        }
      ]
    },
    {
      "endpoint": "/admin/maintenance",
      "method": "POST",
      "test_cases": [
        {
          "name": "toggle_maintenance_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Aktivace udrzby"
        }
      ]
    },
    {
      "endpoint": "/catalog",
      "method": "GET",
      "test_cases": [
        {
          "name": "deprecated_catalog_redirect",
          "type": "happy_path",
          "expected_status": 301,
          "description": "Presmerovani deprecated katalogu"
        }
      ]
    }
  ]
}