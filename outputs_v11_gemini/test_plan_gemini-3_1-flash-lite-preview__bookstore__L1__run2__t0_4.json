{
  "test_plan": [
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne vytvoreni autora s validnimi daty"
        },
        {
          "name": "create_author_invalid_name",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba pri prazdnem jmenu autora"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_conflict",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat autora s existujicimi knihami"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni knihy se vsemi povinnymi poli"
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Konflikt pri pouziti stejneho ISBN"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_soft_deleted_book",
          "type": "error",
          "expected_status": 410,
          "description": "Pokus o ziskani smazane knihy vraci 410"
        },
        {
          "name": "get_book_etag_304",
          "type": "happy_path",
          "expected_status": 304,
          "description": "Podmineny GET vraci 304 pri shode ETag"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_book_etag_mismatch",
          "type": "error",
          "expected_status": 412,
          "description": "Update selze pri neshode ETag"
        },
        {
          "name": "update_book_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Update neexistujici knihy vraci 404"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/restore",
      "method": "POST",
      "test_cases": [
        {
          "name": "restore_deleted_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Uspesne obnoveni smazane knihy"
        },
        {
          "name": "restore_active_book_error",
          "type": "error",
          "expected_status": 400,
          "description": "Nelze obnovit knihu, ktera neni smazana"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_new_book_error",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na novou knihu neni povolena"
        },
        {
          "name": "apply_discount_rate_limit",
          "type": "error",
          "expected_status": 429,
          "description": "Prekroceni limitu 5 req/10s"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_insufficient",
          "type": "error",
          "expected_status": 400,
          "description": "Pokus o zaporny sklad vraci 400"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/cover",
      "method": "POST",
      "test_cases": [
        {
          "name": "upload_cover_too_large",
          "type": "error",
          "expected_status": 413,
          "description": "Soubor nad 2MB vraci 413"
        },
        {
          "name": "upload_cover_invalid_type",
          "type": "error",
          "expected_status": 415,
          "description": "Nepodporovany typ souboru vraci 415"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne pridani recenze"
        }
      ]
    },
    {
      "endpoint": "/books/bulk",
      "method": "POST",
      "test_cases": [
        {
          "name": "bulk_create_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Chybejici API klice u bulk operace"
        },
        {
          "name": "bulk_create_partial_success",
          "type": "happy_path",
          "expected_status": 207,
          "description": "Castecny uspech pri hromadnem vytvareni"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Objednavka selze pri nedostatku skladu"
        },
        {
          "name": "create_order_duplicate_book",
          "type": "error",
          "expected_status": 400,
          "description": "Duplicitni polozky v objednavce"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_status_invalid_transition",
          "type": "error",
          "expected_status": 400,
          "description": "Nepovoleny prechod stavu objednavky"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/invoice",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_invoice_pending_forbidden",
          "type": "error",
          "expected_status": 403,
          "description": "Faktura pro pending objednavku zakazana"
        }
      ]
    },
    {
      "endpoint": "/exports/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "start_export_success",
          "type": "happy_path",
          "expected_status": 202,
          "description": "Uspesne spusteni asynchronniho exportu"
        }
      ]
    },
    {
      "endpoint": "/exports/{job_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_export_processing",
          "type": "happy_path",
          "expected_status": 202,
          "description": "Polling exportu v prubehu"
        }
      ]
    },
    {
      "endpoint": "/admin/maintenance",
      "method": "POST",
      "test_cases": [
        {
          "name": "toggle_maintenance_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Uspesne prepnuti rezimu udrzby"
        }
      ]
    },
    {
      "endpoint": "/statistics/summary",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_stats_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Statistiky vyzaduji API klic"
        },
        {
          "name": "get_stats_invalid_date_range",
          "type": "error",
          "expected_status": 400,
          "description": "Nevalidni format casoveho rozsahu statistik"
        }
      ]
    },
    {
      "endpoint": "/catalog",
      "method": "GET",
      "test_cases": [
        {
          "name": "catalog_redirect_301",
          "type": "happy_path",
          "expected_status": 301,
          "description": "Deprecated catalog presmerovava na books"
        }
      ]
    },
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "health_check_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Standardni health check"
        }
      ]
    }
  ]
}