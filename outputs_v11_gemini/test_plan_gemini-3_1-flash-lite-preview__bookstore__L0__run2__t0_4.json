{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "health_check_ok",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni dostupnosti API"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne vytvoreni knihy s validnimi daty"
        },
        {
          "name": "create_book_invalid_price",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoreni knihy se zapornou cenou"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni strankovani seznamu knih"
        },
        {
          "name": "list_books_invalid_page",
          "type": "error",
          "expected_status": 422,
          "description": "Dotaz na stranku mensi nez 1"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_book_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Pokus o ziskani neexistujici knihy"
        },
        {
          "name": "get_deleted_book",
          "type": "edge_case",
          "expected_status": 410,
          "description": "Ziskani knihy po provedeni soft delete"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_book_etag_mismatch",
          "type": "edge_case",
          "expected_status": 412,
          "description": "Aktualizace knihy se spatnym ETag"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_book_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Uspesne provedeni soft delete"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/restore",
      "method": "POST",
      "test_cases": [
        {
          "name": "restore_non_deleted_book",
          "type": "error",
          "expected_status": 400,
          "description": "Obnova knihy, ktera nebyla smazana"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_rate_limit",
          "type": "edge_case",
          "expected_status": 429,
          "description": "Prekroceni limitu pozadavku pro slevy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/cover",
      "method": "POST",
      "test_cases": [
        {
          "name": "upload_cover_invalid_type",
          "type": "error",
          "expected_status": 415,
          "description": "Nahrani nepodporovaneho formatu obalky"
        },
        {
          "name": "upload_cover_too_large",
          "type": "error",
          "expected_status": 413,
          "description": "Nahrani souboru vetsiho nez 2MB"
        }
      ]
    },
    {
      "endpoint": "/books/bulk",
      "method": "POST",
      "test_cases": [
        {
          "name": "bulk_create_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Hromadne vytvoreni bez API klice"
        },
        {
          "name": "bulk_create_limit_exceeded",
          "type": "edge_case",
          "expected_status": 429,
          "description": "Prekroceni rate limitu pro bulk endpoint"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne vytvoreni autora"
        },
        {
          "name": "create_author_invalid_name",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoreni autora s prazdnym jmenem"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_author_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Uspesna aktualizace udaju autora"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne vytvoreni kategorie"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne vytvoreni objednavky"
        },
        {
          "name": "create_order_empty_items",
          "type": "error",
          "expected_status": 422,
          "description": "Objednavka bez polozek"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_order_status_invalid",
          "type": "error",
          "expected_status": 422,
          "description": "Nastaveni neexistujiciho statusu objednavky"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_too_long",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoreni tagu s nazvem nad 30 znaku"
        }
      ]
    },
    {
      "endpoint": "/exports/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "start_export_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Spusteni exportu bez API klice"
        },
        {
          "name": "start_export_success",
          "type": "happy_path",
          "expected_status": 202,
          "description": "Uspesne zahajeni asynchronniho exportu"
        }
      ]
    },
    {
      "endpoint": "/exports/{job_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_export_status_pending",
          "type": "happy_path",
          "expected_status": 202,
          "description": "Overeni stavu probihajiciho exportu"
        },
        {
          "name": "get_export_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Dotaz na neexistujici job exportu"
        }
      ]
    },
    {
      "endpoint": "/admin/maintenance",
      "method": "POST",
      "test_cases": [
        {
          "name": "toggle_maintenance_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Uspesne prepnuti udrzby"
        }
      ]
    },
    {
      "endpoint": "/statistics/summary",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_statistics_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ziskani statistik knihkupectvi"
        }
      ]
    },
    {
      "endpoint": "/catalog",
      "method": "GET",
      "test_cases": [
        {
          "name": "deprecated_catalog_redirect",
          "type": "edge_case",
          "expected_status": 301,
          "description": "Overeni presmerovani deprecated endpointu"
        }
      ]
    }
  ]
}