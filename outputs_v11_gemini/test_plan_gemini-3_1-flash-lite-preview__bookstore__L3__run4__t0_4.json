{
  "test_plan": [
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření platného autora"
        },
        {
          "name": "create_author_invalid_name",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoření autora s prázdným jménem"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_author_etag_mismatch",
          "type": "error",
          "expected_status": 412,
          "description": "Aktualizace autora s chybným If-Match ETagem"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_conflict",
          "type": "error",
          "expected_status": 409,
          "description": "Smazání autora, který má přiřazené knihy"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření knihy s validními údaji"
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Vytvoření knihy s již existujícím ISBN"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_book_soft_deleted",
          "type": "edge_case",
          "expected_status": 410,
          "description": "Pokus o získání detailu smazané knihy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_book_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Úspěšné provedení soft delete knihy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/restore",
      "method": "POST",
      "test_cases": [
        {
          "name": "restore_book_not_deleted",
          "type": "error",
          "expected_status": 400,
          "description": "Pokus o obnovení knihy, která nebyla smazána"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_too_new_book",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na knihu mladší 1 roku"
        },
        {
          "name": "apply_discount_rate_limit",
          "type": "error",
          "expected_status": 429,
          "description": "Překročení rate limitu pro slevy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_insufficient",
          "type": "error",
          "expected_status": 400,
          "description": "Vyskladnění více kusů než je na skladě"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/cover",
      "method": "POST",
      "test_cases": [
        {
          "name": "upload_cover_unsupported_type",
          "type": "error",
          "expected_status": 415,
          "description": "Nahrání souboru jiného typu než JPEG/PNG"
        },
        {
          "name": "upload_cover_too_large",
          "type": "error",
          "expected_status": 413,
          "description": "Nahrání souboru většího než 2 MB"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Recenze s hodnocením mimo rozsah 1-5"
        }
      ]
    },
    {
      "endpoint": "/books/bulk",
      "method": "POST",
      "test_cases": [
        {
          "name": "bulk_create_partial_success",
          "type": "happy_path",
          "expected_status": 207,
          "description": "Částečný úspěch při hromadném vytváření knih"
        },
        {
          "name": "bulk_create_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Chybějící API klíč u bulk operace"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/clone",
      "method": "POST",
      "test_cases": [
        {
          "name": "clone_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Klonování knihy s existujícím ISBN"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_duplicate_name",
          "type": "error",
          "expected_status": 409,
          "description": "Vytvoření kategorie s již existujícím názvem"
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_tag_in_use",
          "type": "error",
          "expected_status": 409,
          "description": "Smazání tagu, který je přiřazen ke knize"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Objednávka knihy s nedostatečným skladem"
        },
        {
          "name": "create_order_duplicate_book_id",
          "type": "error",
          "expected_status": 400,
          "description": "Duplicitní položka v objednávce"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_order_invalid_transition",
          "type": "error",
          "expected_status": 400,
          "description": "Nepovolený přechod stavu objednávky"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/invoice",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_invoice_pending_forbidden",
          "type": "error",
          "expected_status": 403,
          "description": "Pokus o fakturu u pending objednávky"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/items",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_item_to_non_pending_order",
          "type": "error",
          "expected_status": 403,
          "description": "Přidání položky do ne-pending objednávky"
        }
      ]
    },
    {
      "endpoint": "/exports/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_export_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Export bez API klíče"
        }
      ]
    },
    {
      "endpoint": "/exports/{job_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_export_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Neexistující export job"
        }
      ]
    },
    {
      "endpoint": "/admin/maintenance",
      "method": "POST",
      "test_cases": [
        {
          "name": "toggle_maintenance_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úspěšné přepnutí maintenance módu"
        }
      ]
    },
    {
      "endpoint": "/statistics/summary",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_statistics_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Přístup ke statistikám bez klíče"
        }
      ]
    },
    {
      "endpoint": "/catalog",
      "method": "GET",
      "test_cases": [
        {
          "name": "deprecated_catalog_redirect",
          "type": "happy_path",
          "expected_status": 301,
          "description": "Ověření přesměrování deprecated endpointu"
        }
      ]
    }
  ]
}