{
  "test_plan": [
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření autora s validními údaji"
        },
        {
          "name": "create_author_invalid_name",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoření autora s prázdným jménem"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_author_etag_mismatch",
          "type": "error",
          "expected_status": 412,
          "description": "Aktualizace autora s nesprávným ETagem"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_conflict",
          "type": "error",
          "expected_status": 409,
          "description": "Smazání autora, který má přiřazené knihy"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření knihy s validními daty"
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Vytvoření knihy s již existujícím ISBN"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination_filter",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Stránkovaný seznam knih s filtrem ceny"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_deleted_book_410",
          "type": "edge_case",
          "expected_status": 410,
          "description": "Pokus o získání detailu smazané knihy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/restore",
      "method": "POST",
      "test_cases": [
        {
          "name": "restore_non_deleted_book",
          "type": "error",
          "expected_status": 400,
          "description": "Obnovení knihy, která nebyla smazána"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_new_book_error",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na knihu vydanou v aktuálním roce"
        },
        {
          "name": "apply_discount_rate_limit",
          "type": "error",
          "expected_status": 429,
          "description": "Překročení rate limitu pro slevy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_insufficient",
          "type": "error",
          "expected_status": 400,
          "description": "Vyskladnění více kusů než je skladem"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/cover",
      "method": "POST",
      "test_cases": [
        {
          "name": "upload_cover_invalid_type",
          "type": "error",
          "expected_status": 415,
          "description": "Nahrání souboru jiného typu než JPEG/PNG"
        },
        {
          "name": "upload_cover_too_large",
          "type": "error",
          "expected_status": 413,
          "description": "Nahrání souboru většího než 2 MB"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Recenze s hodnocením mimo rozsah 1-5"
        }
      ]
    },
    {
      "endpoint": "/books/bulk",
      "method": "POST",
      "test_cases": [
        {
          "name": "bulk_create_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Hromadné vytvoření bez API klíče"
        },
        {
          "name": "bulk_create_partial_success",
          "type": "happy_path",
          "expected_status": 207,
          "description": "Částečný úspěch při hromadném vytvoření"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/clone",
      "method": "POST",
      "test_cases": [
        {
          "name": "clone_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Klonování knihy s existujícím ISBN"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_duplicate_tag",
          "type": "error",
          "expected_status": 409,
          "description": "Vytvoření tagu se stejným názvem"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Objednávka knihy s nulovým skladem"
        },
        {
          "name": "create_order_duplicate_book_id",
          "type": "error",
          "expected_status": 400,
          "description": "Objednávka se stejným book_id v položkách"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "invalid_status_transition",
          "type": "error",
          "expected_status": 400,
          "description": "Přechod ze stavu delivered na pending"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/invoice",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_invoice_forbidden_state",
          "type": "error",
          "expected_status": 403,
          "description": "Faktura pro objednávku ve stavu pending"
        }
      ]
    },
    {
      "endpoint": "/exports/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "start_export_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Export bez API klíče"
        }
      ]
    },
    {
      "endpoint": "/exports/{job_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_export_job_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Dotaz na neexistující exportní job"
        }
      ]
    },
    {
      "endpoint": "/admin/maintenance",
      "method": "POST",
      "test_cases": [
        {
          "name": "toggle_maintenance_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Aktivace maintenance módu"
        }
      ]
    },
    {
      "endpoint": "/statistics/summary",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_stats_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Statistiky bez API klíče"
        }
      ]
    },
    {
      "endpoint": "/catalog",
      "method": "GET",
      "test_cases": [
        {
          "name": "deprecated_catalog_redirect",
          "type": "happy_path",
          "expected_status": 301,
          "description": "Ověření přesměrování z /catalog"
        }
      ]
    },
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "health_check_ok",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Základní health check"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_nonexistent_tag_to_book",
          "type": "error",
          "expected_status": 404,
          "description": "Přidání tagu, který neexistuje"
        }
      ]
    }
  ]
}