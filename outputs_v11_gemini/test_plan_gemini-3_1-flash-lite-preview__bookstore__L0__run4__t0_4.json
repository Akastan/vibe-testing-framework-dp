{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "health_check_ok",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni dostupnosti API"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni autora s validnimi daty"
        },
        {
          "name": "create_author_invalid_name",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoreni autora s prazdnym jmenem"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_author_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Ziskani neexistujiciho autora"
        },
        {
          "name": "get_author_etag_not_modified",
          "type": "edge_case",
          "expected_status": 304,
          "description": "Overeni ETag cache"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni knihy s validnimi daty"
        },
        {
          "name": "create_book_invalid_price",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoreni knihy se zapornou cenou"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni strankovani seznamu knih"
        },
        {
          "name": "list_books_invalid_page",
          "type": "error",
          "expected_status": 422,
          "description": "Overeni validace stranky mimo rozsah"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_deleted_book_gone",
          "type": "edge_case",
          "expected_status": 410,
          "description": "Ziskani smazane knihy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_book_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Soft delete knihy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/restore",
      "method": "POST",
      "test_cases": [
        {
          "name": "restore_active_book_error",
          "type": "error",
          "expected_status": 400,
          "description": "Obnova knihy, ktera neni smazana"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_rate_limit",
          "type": "error",
          "expected_status": 429,
          "description": "Prekroceni rate limitu pro slevy"
        },
        {
          "name": "apply_discount_invalid_value",
          "type": "error",
          "expected_status": 422,
          "description": "Sleva mimo povoleny rozsah"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/cover",
      "method": "POST",
      "test_cases": [
        {
          "name": "upload_cover_too_large",
          "type": "error",
          "expected_status": 413,
          "description": "Nahrani prilis velkeho souboru"
        },
        {
          "name": "upload_cover_wrong_type",
          "type": "error",
          "expected_status": 415,
          "description": "Nahrani nepodporovaneho formatu"
        }
      ]
    },
    {
      "endpoint": "/books/bulk",
      "method": "POST",
      "test_cases": [
        {
          "name": "bulk_create_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Chybejici API klic u bulk operace"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni objednavky"
        },
        {
          "name": "create_order_no_items",
          "type": "error",
          "expected_status": 422,
          "description": "Objednavka bez polozek"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_status_invalid",
          "type": "error",
          "expected_status": 422,
          "description": "Nastaveni neexistujiciho statusu"
        }
      ]
    },
    {
      "endpoint": "/exports/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "export_books_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Export bez API klice"
        }
      ]
    },
    {
      "endpoint": "/exports/{job_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_export_job_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Ziskani neexistujiciho exportu"
        }
      ]
    },
    {
      "endpoint": "/admin/maintenance",
      "method": "POST",
      "test_cases": [
        {
          "name": "toggle_maintenance_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Zmena rezimu bez admin prav"
        }
      ]
    },
    {
      "endpoint": "/statistics/summary",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_statistics_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ziskani statistik"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni kategorie"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni tagu"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_empty_list",
          "type": "error",
          "expected_status": 422,
          "description": "Pridani prazdneho seznamu tagu"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Recenze s hodnocenim mimo 1-5"
        },
        {
          "name": "create_review_duplicate",
          "type": "error",
          "expected_status": 409,
          "description": "Zabraneni duplicitni recenze od stejneho uzivatele"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_order_forbidden",
          "type": "error",
          "expected_status": 403,
          "description": "Pokus o pristup k objednavce jineho uzivatele"
        }
      ]
    }
  ]
}