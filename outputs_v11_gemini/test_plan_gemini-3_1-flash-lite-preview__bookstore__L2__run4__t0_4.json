{
  "test_plan": [
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni autora s validnimi daty"
        },
        {
          "name": "create_author_invalid_name",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoreni autora s prazdnym jmenem"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_author_etag_304",
          "type": "happy_path",
          "expected_status": 304,
          "description": "Overeni 304 pri shode ETag"
        },
        {
          "name": "get_author_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Pokus o ziskani neexistujiciho autora"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_conflict",
          "type": "error",
          "expected_status": 409,
          "description": "Smazani autora, ktery ma knihy"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni knihy s validnimi daty"
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Vytvoreni knihy s duplicitnim ISBN"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni strankovani seznamu knih"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "soft_delete_book_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Provedeni soft delete u knihy"
        },
        {
          "name": "get_deleted_book_410",
          "type": "error",
          "expected_status": 410,
          "description": "Pokus o ziskani smazane knihy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/restore",
      "method": "POST",
      "test_cases": [
        {
          "name": "restore_deleted_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Obnoveni smazane knihy"
        },
        {
          "name": "restore_non_deleted_book_400",
          "type": "error",
          "expected_status": 400,
          "description": "Obnoveni knihy, ktera nebyla smazana"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Aplikace slevy na starou knihu"
        },
        {
          "name": "apply_discount_new_book_400",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na novou knihu (mladsi 1 roku)"
        },
        {
          "name": "apply_discount_rate_limit",
          "type": "error",
          "expected_status": 429,
          "description": "Prekroceni rate limitu pro slevy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Uspesne naskladneni knihy"
        },
        {
          "name": "update_stock_negative_400",
          "type": "error",
          "expected_status": 400,
          "description": "Zaporny sklad po vyskladneni"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/cover",
      "method": "POST",
      "test_cases": [
        {
          "name": "upload_cover_unsupported_type",
          "type": "error",
          "expected_status": 415,
          "description": "Nahrani nepovoleneho typu souboru"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni recenze pro knihu"
        },
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoreni recenze s hodnocenim mimo rozsah 1-5"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_to_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Pridani tagu ke knize"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni objednavky"
        },
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Objednavka s nedostatkem skladu"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_order_status_invalid_transition",
          "type": "error",
          "expected_status": 400,
          "description": "Nepovoleny prechod stavu objednavky"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/invoice",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_invoice_pending_403",
          "type": "error",
          "expected_status": 403,
          "description": "Ziskani faktury pro pending objednavku"
        }
      ]
    },
    {
      "endpoint": "/books/bulk",
      "method": "POST",
      "test_cases": [
        {
          "name": "bulk_create_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Bulk vytvoreni bez API klice"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/clone",
      "method": "POST",
      "test_cases": [
        {
          "name": "clone_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Klonovani knihy"
        }
      ]
    },
    {
      "endpoint": "/exports/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "start_book_export_success",
          "type": "happy_path",
          "expected_status": 202,
          "description": "Spusteni asynchronniho exportu knih"
        }
      ]
    },
    {
      "endpoint": "/statistics/summary",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_statistics_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Ziskani statistik bez API klice"
        }
      ]
    },
    {
      "endpoint": "/admin/maintenance",
      "method": "POST",
      "test_cases": [
        {
          "name": "toggle_maintenance_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Aktivace udrzby"
        }
      ]
    }
  ]
}