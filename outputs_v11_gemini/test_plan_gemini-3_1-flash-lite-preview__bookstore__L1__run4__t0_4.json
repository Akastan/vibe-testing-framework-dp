{
  "test_plan": [
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni autora s validnimi daty"
        },
        {
          "name": "create_author_invalid_name",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoreni autora s prazdnym jmenem"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_author_etag_mismatch",
          "type": "error",
          "expected_status": 412,
          "description": "Aktualizace autora s neplatnym If-Match ETagem"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni knihy s validnimi parametry"
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Vytvoreni knihy s jiz existujicim ISBN"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_book_soft_deleted",
          "type": "edge_case",
          "expected_status": 410,
          "description": "Pokus o ziskani detailu smazane knihy"
        },
        {
          "name": "get_book_nonexistent",
          "type": "error",
          "expected_status": 404,
          "description": "Pokus o ziskani neexistujici knihy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/restore",
      "method": "POST",
      "test_cases": [
        {
          "name": "restore_active_book",
          "type": "error",
          "expected_status": 400,
          "description": "Obnoveni knihy, ktera neni smazana"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_too_high",
          "type": "error",
          "expected_status": 422,
          "description": "Sleva vyssi nez 50 procent"
        },
        {
          "name": "apply_discount_new_book",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na knihu vydanou v aktualnim roce"
        },
        {
          "name": "apply_discount_rate_limit",
          "type": "error",
          "expected_status": 429,
          "description": "Prekroceni rate limitu pro slevy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_negative_result",
          "type": "error",
          "expected_status": 400,
          "description": "Vyskladneni vedouci k zaporne hodnote skladu"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/cover",
      "method": "POST",
      "test_cases": [
        {
          "name": "upload_cover_unsupported_type",
          "type": "error",
          "expected_status": 415,
          "description": "Nahrani souboru jineho typu nez JPEG/PNG"
        },
        {
          "name": "upload_cover_too_large",
          "type": "error",
          "expected_status": 413,
          "description": "Nahrani souboru vetsiho nez 2MB"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Recenze s hodnocenim mimo rozsah 1-5"
        }
      ]
    },
    {
      "endpoint": "/books/bulk",
      "method": "POST",
      "test_cases": [
        {
          "name": "bulk_create_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Hromadne vytvoreni bez API klice"
        },
        {
          "name": "bulk_create_partial_success",
          "type": "happy_path",
          "expected_status": 207,
          "description": "Castecny uspech hromadneho vytvareni"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Objednavka knihy s nulovym skladem"
        },
        {
          "name": "create_order_duplicate_book",
          "type": "error",
          "expected_status": 400,
          "description": "Objednavka se stejnym book_id v polozkach"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_status_invalid_transition",
          "type": "error",
          "expected_status": 400,
          "description": "Prechod z delivered na pending"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/invoice",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_invoice_pending_order",
          "type": "error",
          "expected_status": 403,
          "description": "Pokus o ziskani faktury u pending objednavky"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/items",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_item_to_shipped_order",
          "type": "error",
          "expected_status": 403,
          "description": "Pridani polozky do jiz odeslane objednavky"
        }
      ]
    },
    {
      "endpoint": "/exports/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "start_export_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Spusteni exportu bez API klice"
        },
        {
          "name": "start_export_invalid_format",
          "type": "error",
          "expected_status": 400,
          "description": "Pozadavek na export v nepodporovanem formatu"
        }
      ]
    },
    {
      "endpoint": "/exports/{job_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_nonexistent_export",
          "type": "error",
          "expected_status": 404,
          "description": "Ziskani stavu neexistujiciho exportu"
        }
      ]
    },
    {
      "endpoint": "/admin/maintenance",
      "method": "POST",
      "test_cases": [
        {
          "name": "toggle_maintenance_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Zmena rezimu udrzby bez API klice"
        }
      ]
    },
    {
      "endpoint": "/statistics/summary",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_stats_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Ziskani statistik bez API klice"
        },
        {
          "name": "get_stats_invalid_date_range",
          "type": "error",
          "expected_status": 422,
          "description": "Statistiky s neplatnym casovym rozsahem"
        }
      ]
    },
    {
      "endpoint": "/catalog",
      "method": "GET",
      "test_cases": [
        {
          "name": "catalog_redirect",
          "type": "happy_path",
          "expected_status": 301,
          "description": "Overeni presmerovani deprecated catalogu"
        }
      ]
    },
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "health_check_ok",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni dostupnosti API"
        }
      ]
    }
  ]
}