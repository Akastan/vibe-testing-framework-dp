{
  "test_plan": [
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni noveho autora s validnimi daty"
        },
        {
          "name": "create_author_invalid_name",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoreni autora s prazdnym jmenem"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_author_etag_304",
          "type": "happy_path",
          "expected_status": 304,
          "description": "Overeni 304 pri shode ETag"
        },
        {
          "name": "get_author_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Pokus o ziskani neexistujiciho autora"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_author_412_mismatch",
          "type": "error",
          "expected_status": 412,
          "description": "Selhani aktualizace pri neshode ETag"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_duplicate_category",
          "type": "error",
          "expected_status": 409,
          "description": "Pokus o vytvoreni duplicitni kategorie"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne vytvoreni knihy"
        },
        {
          "name": "create_book_invalid_price",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoreni knihy se zapornou cenou"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_deleted_book_410",
          "type": "error",
          "expected_status": 410,
          "description": "Pokus o ziskani smazane knihy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "soft_delete_book_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Uspesne provedeni soft delete"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/restore",
      "method": "POST",
      "test_cases": [
        {
          "name": "restore_non_deleted_book",
          "type": "error",
          "expected_status": 400,
          "description": "Pokus o obnovu knihy, ktera neni smazana"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_new_book_error",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na knihu mladsi nez 1 rok"
        },
        {
          "name": "apply_discount_rate_limit",
          "type": "error",
          "expected_status": 429,
          "description": "Prekroceni rate limitu pro slevy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_negative_result",
          "type": "error",
          "expected_status": 400,
          "description": "Vysledny sklad by byl zaporny"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/cover",
      "method": "POST",
      "test_cases": [
        {
          "name": "upload_cover_invalid_type",
          "type": "error",
          "expected_status": 415,
          "description": "Nahrani nepodporovaneho typu souboru"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne pridani recenze"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_to_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Uspesne prirazeni tagu ke knize"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Objednavka s nedostatkem skladu"
        },
        {
          "name": "create_order_duplicate_items",
          "type": "error",
          "expected_status": 400,
          "description": "Duplicitni book_id v polozkach objednavky"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "invalid_order_status_transition",
          "type": "error",
          "expected_status": 400,
          "description": "Nepovoleny prechod stavu objednavky"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/invoice",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_invoice_forbidden_state",
          "type": "error",
          "expected_status": 403,
          "description": "Faktura pro pending objednavku"
        }
      ]
    },
    {
      "endpoint": "/books/bulk",
      "method": "POST",
      "test_cases": [
        {
          "name": "bulk_create_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Chybejici API klice u bulk operace"
        },
        {
          "name": "bulk_create_partial_success",
          "type": "happy_path",
          "expected_status": 207,
          "description": "Castecny uspech pri bulk vytvareni"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/clone",
      "method": "POST",
      "test_cases": [
        {
          "name": "clone_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Klonovani s existujicim ISBN"
        }
      ]
    },
    {
      "endpoint": "/exports/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "start_export_success",
          "type": "happy_path",
          "expected_status": 202,
          "description": "Uspesne zahajeni asynchronniho exportu"
        }
      ]
    },
    {
      "endpoint": "/exports/{job_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "poll_export_processing",
          "type": "happy_path",
          "expected_status": 202,
          "description": "Polling exportu, ktery jeste bezi"
        }
      ]
    },
    {
      "endpoint": "/admin/maintenance",
      "method": "POST",
      "test_cases": [
        {
          "name": "toggle_maintenance_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Uspesne prepnuti udrzby"
        }
      ]
    },
    {
      "endpoint": "/statistics/summary",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_statistics_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Pokus o ziskani statistik bez klice"
        }
      ]
    },
    {
      "endpoint": "/catalog",
      "method": "GET",
      "test_cases": [
        {
          "name": "deprecated_catalog_redirect",
          "type": "happy_path",
          "expected_status": 301,
          "description": "Overeni presmerovani z /catalog"
        },
        {
          "name": "catalog_invalid_query_params",
          "type": "error",
          "expected_status": 400,
          "description": "Validace neplatnych filtru v katalogu"
        }
      ]
    }
  ]
}