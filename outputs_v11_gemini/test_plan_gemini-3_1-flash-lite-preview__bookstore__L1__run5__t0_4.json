{
  "test_plan": [
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření autora s validními údaji"
        },
        {
          "name": "create_author_invalid_name",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoření autora s prázdným jménem"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_author_etag_mismatch",
          "type": "error",
          "expected_status": 412,
          "description": "Aktualizace autora s chybným ETag v If-Match"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření knihy s platnými parametry"
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Vytvoření knihy s již existujícím ISBN"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření stránkování seznamu knih"
        },
        {
          "name": "list_books_filter_price",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrování knih podle cenového rozpětí"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_deleted_book_410",
          "type": "edge_case",
          "expected_status": 410,
          "description": "Pokus o získání detailu smazané knihy"
        },
        {
          "name": "get_book_not_modified",
          "type": "edge_case",
          "expected_status": 304,
          "description": "Podmíněný GET s If-None-Match"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/restore",
      "method": "POST",
      "test_cases": [
        {
          "name": "restore_active_book_400",
          "type": "error",
          "expected_status": 400,
          "description": "Pokus o obnovení knihy, která nebyla smazána"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_too_high",
          "type": "error",
          "expected_status": 422,
          "description": "Sleva vyšší než 50 procent"
        },
        {
          "name": "apply_discount_new_book_400",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na knihu vydanou v aktuálním roce"
        },
        {
          "name": "apply_discount_rate_limit",
          "type": "error",
          "expected_status": 429,
          "description": "Překročení rate limitu pro slevy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_insufficient",
          "type": "error",
          "expected_status": 400,
          "description": "Vyskladnění vedoucí k zápornému stavu"
        },
        {
          "name": "update_stock_invalid_format",
          "type": "error",
          "expected_status": 400,
          "description": "Pokus o nastavení nečíselné hodnoty zásob"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/cover",
      "method": "POST",
      "test_cases": [
        {
          "name": "upload_cover_unsupported_type",
          "type": "error",
          "expected_status": 415,
          "description": "Nahrání souboru jiného typu než JPEG/PNG"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Recenze s hodnocením mimo rozsah 1-5"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Objednávka knihy s nulovým skladem"
        },
        {
          "name": "create_order_duplicate_items",
          "type": "error",
          "expected_status": 400,
          "description": "Duplicitní položky v jedné objednávce"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "invalid_status_transition",
          "type": "error",
          "expected_status": 400,
          "description": "Přechod ze stavu delivered do pending"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/invoice",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_invoice_pending_forbidden",
          "type": "error",
          "expected_status": 403,
          "description": "Pokus o získání faktury pro pending objednávku"
        }
      ]
    },
    {
      "endpoint": "/books/bulk",
      "method": "POST",
      "test_cases": [
        {
          "name": "bulk_create_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Hromadné vytvoření bez API klíče"
        },
        {
          "name": "bulk_create_partial_success",
          "type": "happy_path",
          "expected_status": 207,
          "description": "Částečný úspěch při hromadném importu"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/clone",
      "method": "POST",
      "test_cases": [
        {
          "name": "clone_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Klonování knihy s existujícím ISBN"
        }
      ]
    },
    {
      "endpoint": "/exports/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "start_export_success",
          "type": "happy_path",
          "expected_status": 202,
          "description": "Úspěšné spuštění asynchronního exportu"
        }
      ]
    },
    {
      "endpoint": "/exports/{job_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_export_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Dotaz na neexistující exportní úlohu"
        }
      ]
    },
    {
      "endpoint": "/admin/maintenance",
      "method": "POST",
      "test_cases": [
        {
          "name": "toggle_maintenance_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Změna režimu údržby bez API klíče"
        }
      ]
    },
    {
      "endpoint": "/statistics/summary",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_statistics_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání statistik s platným API klíčem"
        },
        {
          "name": "get_statistics_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Přístup ke statistikám bez autorizace"
        }
      ]
    },
    {
      "endpoint": "/catalog",
      "method": "GET",
      "test_cases": [
        {
          "name": "catalog_deprecated_redirect",
          "type": "happy_path",
          "expected_status": 301,
          "description": "Ověření přesměrování deprecated endpointu"
        }
      ]
    }
  ]
}