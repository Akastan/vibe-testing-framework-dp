{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "check_api_health",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření dostupnosti API"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_valid_author",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření autora"
        },
        {
          "name": "create_invalid_author_missing_name",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba při absenci povinného jména"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat autora s knihami"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_duplicate_category_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní název kategorie vrací konflikt"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_with_nonexistent_author",
          "type": "error",
          "expected_status": 404,
          "description": "Vytvoření knihy s neexistujícím autorem"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_book_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Úspěšné smazání knihy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_negative_results_error",
          "type": "error",
          "expected_status": 400,
          "description": "Odečtení skladu pod nulu vrací 400"
        },
        {
          "name": "update_stock_invalid_format",
          "type": "error",
          "expected_status": 422,
          "description": "Nevalidní datový typ pro quantity"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_out_of_range_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Hodnocení mimo rozsah 1-5"
        },
        {
          "name": "create_review_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vložení recenze"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_no_reviews",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Kniha bez recenzí vrací null"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_too_high",
          "type": "error",
          "expected_status": 422,
          "description": "Sleva vyšší než 50 procent"
        },
        {
          "name": "apply_discount_new_book_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Nelze slevit knihu mladší než 1 rok"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_nonexistent_tag_to_book",
          "type": "error",
          "expected_status": 404,
          "description": "Přidání neexistujícího tagu"
        },
        {
          "name": "add_duplicate_tag_idempotency",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Opakované přidání stejného tagu ignorováno"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tag_from_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úspěšné odstranění tagu z knihy"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_too_long",
          "type": "error",
          "expected_status": 422,
          "description": "Název tagu delší než 30 znaků"
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_assigned_tag_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat tag přiřazený ke knize"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_empty_items",
          "type": "error",
          "expected_status": 422,
          "description": "Objednávka bez položek"
        },
        {
          "name": "create_order_duplicate_books",
          "type": "error",
          "expected_status": 400,
          "description": "Duplicitní book_id v položkách"
        },
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Nedostatek skladu pro objednávku"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_confirmed_order_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Nelze smazat potvrzenou objednávku"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_status_illegal_transition",
          "type": "error",
          "expected_status": 400,
          "description": "Nepovolený přechod stavu objednávky"
        },
        {
          "name": "update_status_invalid_value",
          "type": "error",
          "expected_status": 422,
          "description": "Stav mimo povolený regex"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination_params",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Výpis knih s parametry stránkování"
        },
        {
          "name": "list_books_invalid_page",
          "type": "error",
          "expected_status": 422,
          "description": "Nevalidní hodnota pro stránku"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_orders_filtering",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrování objednávek dle jména"
        },
        {
          "name": "list_orders_page_size_edge_case",
          "type": "edge_case",
          "expected_status": 200,
          "description": "Maximální velikost stránky 100"
        },
        {
          "name": "list_orders_empty_results",
          "type": "edge_case",
          "expected_status": 200,
          "description": "Dotaz na prázdný seznam"
        }
      ]
    }
  ]
}