{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_health_status",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni ze API bezi"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_valid_author",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni noveho autora"
        },
        {
          "name": "create_invalid_author_no_name",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba pri chybejicim jmenu"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Smazani autora s knihami zakazano"
        },
        {
          "name": "delete_nonexistent_author",
          "type": "error",
          "expected_status": 404,
          "description": "Smazani neexistujiciho autora"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_valid_category",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni kategorie"
        },
        {
          "name": "create_duplicate_category",
          "type": "error",
          "expected_status": 409,
          "description": "Unikatnost nazvu kategorie"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_valid_book_with_stock",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni knihy se stock=10"
        },
        {
          "name": "create_book_invalid_isbn",
          "type": "error",
          "expected_status": 422,
          "description": "Validace delky ISBN"
        },
        {
          "name": "create_book_missing_author",
          "type": "error",
          "expected_status": 404,
          "description": "Neexistujici autor"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_existing_book_details",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ziskani detailu knihy"
        },
        {
          "name": "get_nonexistent_book",
          "type": "error",
          "expected_status": 404,
          "description": "404 pro neexistujici id"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_valid_review",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Validni recenze"
        },
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Rating mimo rozsah 1-5"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_empty_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Rating kdyz nejsou recenze"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_old_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Sleva pro knihu > 1 rok"
        },
        {
          "name": "apply_discount_new_book_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva zakazana pro novou knihu"
