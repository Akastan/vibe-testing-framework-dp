{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_health_status",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření dostupnosti API"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření nového autora"
        },
        {
          "name": "create_author_invalid_data",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba při odeslání prázdného jména"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_conflict",
          "type": "error",
          "expected_status": 409,
          "description": "Smazání autora s knihami vrací 409"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_duplicate_name",
          "type": "error",
          "expected_status": 409,
          "description": "Vytvoření kategorie s existujícím názvem"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_missing_author",
          "type": "error",
          "expected_status": 404,
          "description": "Vytvoření knihy pro neexistujícího autora"
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Vytvoření knihy s duplicitním ISBN"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Výpis knih se stránkováním"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Přidání recenze ke knize"
        },
        {
          "name": "create_review_out_of_range",
          "type": "error",
          "expected_status": 422,
          "description": "Recenze s hodnocením 6 (mimo limit)"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_empty",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Kniha bez recenzí vrací null"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_too_recent_book",
          "type": "error",
          "expected_status": 400,
          "description": "Nelze slevit knihu mladší 1 roku"
        },
        {
          "name": "apply_discount_invalid_percent",
          "type": "error",
          "expected_status": 422,
          "description": "Sleva 60 % (nad limit 50 %)"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_negative_result",
          "type": "error",
          "expected_status": 400,
          "description": "Odebrání skladu pod nulu"
        },
        {
          "name": "update_stock_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Validní navýšení skladu"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření nového tagu"
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_assigned_tag_conflict",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat tag přiřazený ke knize"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Přidání tagů ke knize"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tags_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Odebrání tagů z knihy"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Vytvoření objednávky bez skladu"
        },
        {
          "name": "create_order_duplicate_book_id",
          "type": "error",
          "expected_status": 400,
          "description": "Duplicita knih v jedné objednávce"
        },
        {
          "name": "create_order_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšná objednávka"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_orders_filtering",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrování objednávek dle jména"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_status_invalid_transition",
          "type": "error",
          "expected_status": 400,
          "description": "Nepovolený přechod stavu objednávky"
        },
        {
          "name": "update_status_shipped_to_delivered",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Povolený přechod do doručeno"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_order_non_pending",
          "type": "error",
          "expected_status": 400,
          "description": "Smazání potvrzené objednávky"
        },
        {
          "name": "delete_order_pending_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání čekající objednávky"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_book_invalid_year",
          "type": "error",
          "expected_status": 422,
          "description": "Aktualizace roku na nevalidní hodnotu"
        }
      ]
    },
    {
      "endpoint": "/categories/{category_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_category_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Získání neexistující kategorie"
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_tag_empty_name",
          "type": "error",
          "expected_status": 422,
          "description": "Aktualizace tagu na prázdný řetězec"
        }
      ]
    }
  ]
}