{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "health_check_returns_ok",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření, že health endpoint vrací status 200 a ok."
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření autora."
        },
        {
          "name": "create_author_invalid_data",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba při chybějícím povinném poli name."
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_error",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat autora, který má přiřazené knihy."
        },
        {
          "name": "delete_author_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Smazání neexistujícího autora vrací 404."
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_duplicate_name",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní název kategorie vyvolá konflikt."
        }
      ]
    },
    {
      "endpoint": "/categories/{category_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_category_with_books_error",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat kategorii s knihami."
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success_default_stock",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření knihy s nastaveným stock na 10."
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "ISBN musí být unikátní."
        },
        {
          "name": "create_book_invalid_year",
          "type": "error",
          "expected_status": 422,
          "description": "Rok vydání mimo povolený rozsah."
        },
        {
          "name": "create_book_missing_required_fields",
          "type": "error",
          "expected_status": 422,
          "description": "Validace při odeslání prázdného JSON objektu."
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření výchozího stránkování."
        },
        {
          "name": "list_books_invalid_page_size",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba při page_size mimo rozsah."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_book_details",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání detailů knihy včetně autorů a tagů."
        },
        {
          "name": "get_book_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Neexistující kniha."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné přidání recenze."
        },
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Rating mimo rozsah 1-5."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_null_for_empty",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Průměrné hodnocení null, pokud kniha nemá recenze."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_old_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Sleva na knihu starší než 1 rok."
        },
        {
          "name": "apply_discount_new_book_fail",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na knihu mladší než 1 rok je zakázána."
        },
        {
          "name": "apply_discount_too_high",
          "type": "error",
          "expected_status": 422,
          "description": "Sleva vyšší než 50% je zakázána validací schématu."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_increase",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Zvýšení počtu kusů na skladě."
        },
        {
          "name": "update_stock_decrease_invalid",
          "type": "error",
          "expected_status": 400,
          "description": "Sklad nesmí být záporný."
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření tagu."
        },
        {
          "name": "create_tag_too_long",
          "type": "error",
          "expected_status": 422,
          "description": "Název tagu delší než 30 znaků."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_to_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Přidání existujících tagů ke knize."
        },
        {
          "name": "add_nonexistent_tag_fail",
          "type": "error",
          "expected_status": 404,
          "description": "Přidání neexistujícího tagu."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tag_from_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Odebrání vazby tagu od knihy."
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Nelze vytvořit objednávku s nedostatečným skladem."
        },
        {
          "name": "create_order_duplicate_items",
          "type": "error",
          "expected_status": 400,
          "description": "Duplicitní knihy v jedné objednávce nejsou povoleny."
        },
        {
          "name": "create_order_invalid_date_format",
          "type": "error",
          "expected_status": 400,
          "description": "Validace formátu data u objednávky."
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_status_pending_to_confirmed",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Povolený přechod stavu objednávky."
        },
        {
          "name": "update_status_invalid_transition",
          "type": "error",
          "expected_status": 400,
          "description": "Nepovolený přechod stavu."
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_pending_order_returns_stock",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání pending objednávky vrací kusy na sklad."
        },
        {
          "name": "delete_shipped_order_fail",
          "type": "error",
          "expected_status": 400,
          "description": "Nelze smazat odeslanou objednávku."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_book_invalid_price",
          "type": "error",
          "expected_status": 422,
          "description": "Změna ceny na zápornou hodnotu."
        },
        {
          "name": "update_book_author_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Změna na neexistujícího autora."
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_author_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání informací o autorovi."
        }
      ]
    },
    {
      "endpoint": "/categories/{category_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_category_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání detailů kategorie."
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_tag_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání detailů tagu."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_reviews_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání všech recenzí ke knize."
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_tag_in_use_error",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat tag, který je přiřazen ke knize."
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_orders_with_customer_filter",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrování objednávek podle jména zákazníka."
        },
        {
          "name": "list_orders_invalid_limit",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba při stránkování mimo rozsah."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_book_cascade_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Úspěšné smazání knihy a jejích vazeb."
        }
      ]
    },
    {
      "endpoint": "/categories/{category_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_category_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úspěšná aktualizace názvu kategorie."
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_author_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úspěšná aktualizace informací o autorovi."
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_tag_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úspěšná aktualizace tagu."
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_order_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání detailu objednávky."
        },
        {
          "name": "get_unauthorized_order_access",
          "type": "error",
          "expected_status": 403,
          "description": "Pokus o přístup k cizí objednávce."
        }
      ]
    }
  ]
}