{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "check_health_status_ok",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření, že API vrací status OK"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření autora s validními údaji"
        },
        {
          "name": "create_author_invalid_data",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba při vytvoření autora bez povinného jména"
        },
        {
          "name": "create_author_invalid_year",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba při zadání roku narození mimo rozsah"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_occupied",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat autora s existujícími knihami"
        },
        {
          "name": "delete_author_nonexistent",
          "type": "error",
          "expected_status": 404,
          "description": "Smazání neexistujícího autora"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření nové kategorie"
        },
        {
          "name": "create_category_duplicate",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze vytvořit kategorii s existujícím názvem"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření knihy s validními daty"
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní ISBN vrací 409"
        },
        {
          "name": "create_book_missing_author",
          "type": "error",
          "expected_status": 422,
          "description": "Chybějící author_id"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření stránkování výsledků knih"
        },
        {
          "name": "list_books_filter_price",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrování knih podle ceny"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_valid",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Sleva na starou knihu"
        },
        {
          "name": "apply_discount_too_recent",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na novou knihu zakázána"
        },
        {
          "name": "apply_discount_over_limit",
          "type": "error",
          "expected_status": 422,
          "description": "Sleva nad 50 procent"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_add",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úspěšné přidání zásob"
        },
        {
          "name": "update_stock_negative",
          "type": "error",
          "expected_status": 400,
          "description": "Výsledek zásob nesmí být záporný"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Přidání validních tagů ke knize"
        },
        {
          "name": "add_nonexistent_tag",
          "type": "error",
          "expected_status": 404,
          "description": "Přidání neexistujícího tagu"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tag_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Odebrání tagu z knihy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření recenze s validním hodnocením"
        },
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Rating mimo rozsah 1-5"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření objednávky s dostatečným skladem"
        },
        {
          "name": "create_order_low_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Objednávka s nedostatečným skladem"
        },
        {
          "name": "create_order_duplicate_items",
          "type": "error",
          "expected_status": 400,
          "description": "Duplicitní ID v položkách objednávky"
        },
        {
          "name": "create_order_empty_cart",
          "type": "error",
          "expected_status": 422,
          "description": "Objednávka bez položek"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "order_status_transition_valid",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Přechod pending -> confirmed"
        },
        {
          "name": "order_status_transition_invalid",
          "type": "error",
          "expected_status": 400,
          "description": "Nepovolený přechod mezi stavy"
        },
        {
          "name": "order_status_cancelled_restores_stock",
          "type": "edge_case",
          "expected_status": 200,
          "description": "Zrušení objednávky vrací sklad"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_pending_order",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání pending objednávky"
        },
        {
          "name": "delete_shipped_order_failed",
          "type": "error",
          "expected_status": 400,
          "description": "Nelze smazat odeslanou objednávku"
        }
      ]
    },
    {
      "endpoint": "/reset",
      "method": "POST",
      "test_cases": [
        {
          "name": "reset_db_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Reset databáze"
        }
      ]
    },
    {
