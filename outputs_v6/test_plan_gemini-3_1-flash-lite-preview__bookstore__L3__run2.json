        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_tag_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Prejmenovani tagu"
        },
        {
          "name": "update_tag_duplicate_name_error",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicita nazvu tagu"
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_unused_tag_success",
