{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_health_status_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni, ze API odpovida OK"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni autora s validnimi daty"
        },
        {
          "name": "create_author_invalid_name",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba pri prazdnem jmenu autora"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_error",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat autora s knihami"
        },
        {
          "name": "delete_nonexistent_author_error",
          "type": "error",
          "expected_status": 404,
          "description": "Smazani neexistujiciho autora"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni nove kategorie"
        },
        {
          "name": "create_duplicate_category_error",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitni nazev kategorie"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni knihy s povolenymi parametry a stock 10"
        },
        {
          "name": "create_book_duplicate_isbn_error",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicate ISBN error"
        },
        {
          "name": "create_book_invalid_year_error",
          "type": "error",
          "expected_status": 422,
          "description": "Rok mimo povoleny rozsah"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_book_detail_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Nacteni detailu knihy"
        },
        {
          "name": "get_nonexistent_book_error",
          "type": "error",
          "expected_status": 404,
          "description": "Book not found"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Pridani recenze ke knize"
        },
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Rating mimo 1-5"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_average_rating_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Vypocet prumerneho hodnoceni"
        },
        {
          "name": "get_rating_empty_reviews",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Prumer kdyz nejsou recenze"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_old_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Sleva pro knihu starsi 1 roku"
        },
        {
          "name": "apply_discount_new_book_error",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva u knihy vydane letos (new book)"
        },
        {
          "name": "apply_discount_exceed_limit_error",
          "type": "error",
          "expected_status": 422,
          "description": "Sleva presahujici 50 procent"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_increase_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Navyseni skladu"
        },
        {
          "name": "update_stock_decrease_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Odecet skladu"
        },
        {
          "name": "update_stock_negative_result_error",
          "type": "error",
          "expected_status": 400,
          "description": "Zaporny vysledny sklad"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni noveho tagu"
        },
        {
          "name": "create_tag_too_long_error",
          "type": "error",
          "expected_status": 422,
          "description": "Tag nazev nad 30 znaku"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_to_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Pridani existujicich tagu ke knize"
        },
        {
          "name": "add_nonexistent_tag_error",
          "type": "error",
          "expected_status": 404,
          "description": "Tag ID neexistuje"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tags_from_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Uspesne odebrani tagu"
        },
        {
          "name": "remove_nonexistent_association_ignore",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Odebirani neprirazeneho tagu (idempotence)"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni objednavky se skladem 10"
        },
        {
          "name": "create_order_insufficient_stock_error",
          "type": "error",
          "expected_status": 400,
          "description": "Nedostatecny sklad knihy"
        },
        {
          "name": "create_order_duplicate_book_id_error",
          "type": "error",
          "expected_status": 400,
          "description": "Stejna kniha dvakrat v objednavce"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "transition_status_pending_to_confirmed_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Prechod pending -> confirmed"
        },
        {
          "name": "transition_status_invalid_order_error",
          "type": "error",
          "expected_status": 400,
          "description": "Nepovoleny prechod stavu"
        },
        {
          "name": "transition_status_cancelled_restores_stock",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Zruseni objednavky vrati sklad"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_pending_order_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazani pending objednavky"
        },
        {
          "name": "delete_delivered_order_error",
          "type": "error",
          "expected_status": 400,
          "description": "Nelze smazat dorucenou objednavku"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "GET",
      "test_cases": [
