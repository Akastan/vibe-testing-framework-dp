          "description": "Vyhledavani knih"
        },
        {
          "name": "list_books_filter_price_range",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrace cen"
        },
        {
          "name": "list_books_invalid_page_error",
          "type": "error",
          "expected_status": 422,
          "description": "Stranka mensi nez 1"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_orders_filtering_name",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrace jmena zakaznika"
        },
        {
          "name": "list_orders_pagination_structure",
