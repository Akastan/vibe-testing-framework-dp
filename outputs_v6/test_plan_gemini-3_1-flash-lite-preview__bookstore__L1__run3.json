          "expected_status": 401,
          "description": "Neplatne heslo vrací 401"
        },
        {
          "name": "login_empty_body",
          "type": "error",
          "expected_status": 400,
          "description": "Prazdny request body vrací 400"
        }
      ]
    },
    {
      "endpoint": "/books/search",
      "method": "GET",
      "test_cases": [
        {
          "name": "search_query_too_short",
          "type": "error",
          "expected_status": 422,
          "description": "Vyhledavaci dotaz kratsi nez 3 znaky"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "partial_update_invalid_field",
          "type": "error",
          "expected_status": 400,
          "description": "Pokus o editaci neexistujiciho pole (schema validation)"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/items",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_item_to_locked_order",
