{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "check_health_status",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni dostupnosti API"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni noveho autora"
        },
        {
          "name": "create_author_invalid_data",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba pri prazdnem jmene autora"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Smazani autora s knihami vrací 409"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne vytvoreni knihy s defaultnim skladem 10"
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitni ISBN vrací 409"
        },
        {
          "name": "create_book_invalid_author",
          "type": "error",
          "expected_status": 404,
          "description": "Neexistujici autor vrací 404"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_paginated",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni strankovani seznamu knih"
        },
        {
          "name": "list_books_search_filter",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrovani knih dle vyhledavani"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_book_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Neexistujici kniha vrací 404"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_valid_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Aplikace slevy na starsi knihu"
        },
        {
          "name": "apply_discount_too_new_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na novou knihu (akt. rok) vrací 400"
        },
        {
          "name": "apply_discount_limit_exceeded",
          "type": "error",
          "expected_status": 422,
          "description": "Sleva nad 50% vrací 422"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "increase_stock_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Navyseni skladu o N"
        },
        {
          "name": "decrease_stock_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Snížení skladu o N"
        },
        {
          "name": "stock_underflow_error",
          "type": "error",
          "expected_status": 400,
          "description": "Zaporny vysledny sklad vrací 400"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_to_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Pridani existujicich tagu ke knize"
        },
        {
          "name": "add_nonexistent_tag_fails",
          "type": "error",
          "expected_status": 404,
          "description": "Tag, ktery neexistuje, vrací 404"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tags_from_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Uspesne odebrani vazeb tagu"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Pridani platne recenze"
        },
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Rating mimo rozsah 1-5"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_book_rating_empty",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Rating u knihy bez recenzi vrací null"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Objednavka bez skladu vrací 400"
        },
        {
          "name": "create_order_duplicate_book",
          "type": "error",
          "expected_status": 400,
          "description": "Duplicitni kniha v objednavce vrací 400"
        },
        {
          "name": "create_order_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni objednavky se snizenim skladu"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "order_status_transition_valid",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Prechod pending na confirmed"
        },
        {
          "name": "order_status_transition_invalid",
          "type": "error",
          "expected_status": 400,
          "description": "Prechod delivered na pending vrací 400"
        },
        {
          "name": "order_status_cancel_returns_stock",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Zruseni objednavky vrati sklad"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_pending_order_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazani pending objednavky"
        },
        {
          "name": "delete_shipped_order_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Smazani odeslane objednavky vrací 400"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_unique_check",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitni nazev tagu vrací 409"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_conflict",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitni kategorie vrací 409"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_book_reviews_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Vypis recenzi knihy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_book_invalid_price",
          "type": "error",
          "expected_status": 422,
          "description": "Aktualizace ceny na zapornou"
        },
        {
          "name": "update_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Uspesna aktualizace udaju knihy"
        }
      ]
    },
    {
      "endpoint": "/categories/{category_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_category_with_books_forbidden",
          "type": "error",
          "expected_status": 409,
          "description": "Smazani kategorie s knihami"
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_tag_in_use_forbidden",
          "type": "error",
          "expected_status": 409,
          "description": "Smazani tagu prirazeneho ke knize"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_orders_filter_customer",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrovani objednavek dle jmena"
        },
        {
          "name": "list_orders_invalid_page",
          "type": "error",
          "expected_status": 422,
          "description": "Strankovani se zapornym cislem"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_book_cascades_reviews",
          "type": "happy_path",
