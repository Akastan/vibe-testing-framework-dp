          "description": "Detail existujici objednavky"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_all_tags",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Seznam vsech tagu"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_all_categories",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Seznam kategorii"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_all_authors",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Seznam autoru"
        }
      ]
    },
    {
      "endpoint": "/auth/login",
      "method": "POST",
      "test_cases": [
        {
          "name": "login_invalid_credentials",
