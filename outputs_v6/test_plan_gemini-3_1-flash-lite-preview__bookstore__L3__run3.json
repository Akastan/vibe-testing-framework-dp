{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "check_api_health",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření dostupnosti API"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření autora"
        },
        {
          "name": "create_author_invalid_data",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba při odeslání prázdného jména"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_conflict",
          "type": "error",
          "expected_status": 409,
          "description": "Smazání autora s knihami zakázáno"
        },
        {
          "name": "delete_nonexistent_author",
          "type": "error",
          "expected_status": 404,
          "description": "Smazání neexistujícího autora"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření kategorie"
        },
        {
          "name": "create_category_duplicate_name",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní název kategorie"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření knihy (stock 10)"
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní ISBN"
        },
        {
          "name": "create_book_invalid_author",
          "type": "error",
          "expected_status": 404,
          "description": "Neexistující autor"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Stránkování seznamu knih"
        },
        {
          "name": "list_books_price_filter",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrování dle ceny"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Přidání recenze"
        },
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Recenze mimo rozsah 1-5"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_no_reviews",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Rating null pokud nejsou recenze"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_new_book_error",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na knihu mladší 1 roku"
        },
        {
          "name": "apply_discount_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Aplikace slevy na starou knihu"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_increase",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Navýšení skladu"
        },
        {
          "name": "update_stock_negative_limit",
          "type": "error",
          "expected_status": 400,
          "description": "Sklad nesmí být záporný"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Přidání tagů ke knize"
        },
        {
          "name": "add_nonexistent_tag",
          "type": "error",
          "expected_status": 404,
          "description": "Tag neexistuje"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tags_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Odebrání tagů"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Objednávka selže při nedostatku skladu"
        },
        {
          "name": "create_order_duplicate_items",
          "type": "error",
          "expected_status": 400,
          "description": "Duplicitní ID v objednávce"
        },
        {
          "name": "create_order_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšná objednávka"
        },
        {
          "name": "create_order_price_capture",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Ověření zachycení unit_price"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "transition_pending_to_confirmed",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Validní přechod statusu"
        },
        {
          "name": "transition_invalid",
          "type": "error",
          "expected_status": 400,
          "description": "Nepovolený přechod statusu"
        },
        {
          "name": "cancel_order_stock_return",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Status cancelled vrátí sklad"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_shipped_order_error",
          "type": "error",
          "expected_status": 400,
          "description": "Nelze smazat odeslanou objednávku"
        },
        {
          "name": "delete_pending_order_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání pending objednávky"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření tagu"
        },
        {
          "name": "create_tag_too_long",
          "type": "error",
          "expected_status": 422,
          "description": "Jméno tagu příliš dlouhé"
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_tag_in_use",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat tag přiřazený ke knize"
        }
      ]
    },
    {
      "endpoint": "/categories/{category_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_category_name",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úprava názvu kategorie"
        },
        {
          "name": "update_category_duplicate",
          "type": "error",
          "expected_status": 409,
          "description": "Update na existující název"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_book_price_invalid",
          "type": "error",
          "expected_status": 422,
          "description": "Cena nesmí být záporná"
        },
        {
          "name": "update_book_isbn_conflict",
          "type": "error",
          "expected_status": 409,
          "description": "Update ISBN na existující"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_book_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Detail neexistující knihy"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_authors_empty",
