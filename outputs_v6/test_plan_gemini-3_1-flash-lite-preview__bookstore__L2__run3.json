          "expected_status": 201,
          "description": "Vytvoreni knihy s povinnym skladem 10"
        },
        {
          "name": "create_book_with_nonexistent_author_fails",
          "type": "error",
          "expected_status": 404,
          "description": "Vytvoreni knihy s chybnym author_id"
        },
        {
          "name": "create_duplicate_isbn_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitni ISBN vraci 409"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination_default",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni defaultniho strankovani"
        },
        {
          "name": "list_books_search_filter",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Vyhledavani knihy podle retezce"
        },
        {
          "name": "list_books_invalid_page_fails",
          "type": "error",
          "expected_status": 422,
          "description": "Nevalidni stranka v parametru vraci 422"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
