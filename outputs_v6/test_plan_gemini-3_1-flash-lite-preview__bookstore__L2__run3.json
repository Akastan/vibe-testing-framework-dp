{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "check_health_status",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni, ze API je zive"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_valid_author",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni validniho autora"
        },
        {
          "name": "create_author_validation_error",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba pri vytvoreni autora bez jmena"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat autora s knihami"
        },
        {
          "name": "delete_nonexistent_author",
          "type": "error",
          "expected_status": 404,
          "description": "Mazani neexistujiciho autora vraci 404"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_duplicate_category_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitni nazev kategorie vyvola konflikt"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success_with_stock_10",
