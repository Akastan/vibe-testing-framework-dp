{
  "test_plan": [
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Verify successful creation of a new author"
        },
        {
          "name": "create_author_invalid_data",
          "type": "error",
          "expected_status": 422,
          "description": "Verify error when name is missing"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_author_not_modified",
          "type": "edge_case",
          "expected_status": 304,
          "description": "Verify 304 response with correct ETag"
        },
        {
          "name": "get_author_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Verify 404 for non-existent author"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Verify successful book creation"
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Verify 409 conflict for duplicate ISBN"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_book_gone_after_delete",
          "type": "edge_case",
          "expected_status": 410,
          "description": "Verify 410 status for soft-deleted book"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Verify discount calculation for old book"
        },
        {
          "name": "apply_discount_too_new_book",
          "type": "error",
          "expected_status": 400,
          "description": "Verify 400 for applying discount to new book"
        },
        {
          "name": "apply_discount_rate_limit",
          "type": "error",
          "expected_status": 429,
          "description": "Verify rate limiting on discount endpoint"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Verify successful stock update"
        },
        {
          "name": "update_stock_insufficient",
          "type": "error",
          "expected_status": 400,
          "description": "Verify 400 when result stock is negative"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/cover",
      "method": "POST",
      "test_cases": [
        {
          "name": "upload_cover_unsupported_type",
          "type": "error",
          "expected_status": 415,
          "description": "Verify 415 for non-image file upload"
        },
        {
          "name": "upload_cover_too_large",
          "type": "error",
          "expected_status": 413,
          "description": "Verify 413 for file exceeding 2MB"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Verify successful review creation"
        }
      ]
    },
    {
      "endpoint": "/books/bulk",
      "method": "POST",
      "test_cases": [
        {
          "name": "bulk_create_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Verify 401 without API key"
        },
        {
          "name": "bulk_create_partial_success",
          "type": "edge_case",
          "expected_status": 207,
          "description": "Verify 207 for mixed success in bulk"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Verify successful order creation"
        },
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Verify 400 for ordering more than stock"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_order_status_invalid_transition",
          "type": "error",
          "expected_status": 400,
          "description": "Verify 400 for illegal status transition"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/invoice",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_invoice_forbidden_pending",
          "type": "error",
          "expected_status": 403,
          "description": "Verify 403 for invoice on pending order"
        }
      ]
    },
    {
      "endpoint": "/exports/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "start_export_success",
          "type": "happy_path",
          "expected_status": 202,
          "description": "Verify 202 accepted for async export"
        }
      ]
    },
    {
      "endpoint": "/exports/{job_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_export_status_processing",
          "type": "edge_case",
          "expected_status": 202,
          "description": "Verify 202 while export is processing"
        },
        {
          "name": "get_export_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Verify 404 for non-existent job"
        }
      ]
    },
    {
      "endpoint": "/admin/maintenance",
      "method": "POST",
      "test_cases": [
        {
          "name": "toggle_maintenance_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Verify maintenance toggle works"
        }
      ]
    },
    {
      "endpoint": "/statistics/summary",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_stats_unauthorized",
          "type": "error",
          "expected_status": 401,
          "description": "Verify 401 for missing API key"
        }
      ]
    },
    {
      "endpoint": "/catalog",
      "method": "GET",
      "test_cases": [
        {
          "name": "deprecated_catalog_redirect",
          "type": "happy_path",
          "expected_status": 301,
          "description": "Verify 301 redirect to /books"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Verify successful tag creation"
        },
        {
          "name": "create_tag_duplicate",
          "type": "error",
          "expected_status": 409,
          "description": "Verify 409 for duplicate tag name"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/restore",
      "method": "POST",
      "test_cases": [
        {
          "name": "restore_non_deleted_book",
          "type": "error",
          "expected_status": 400,
          "description": "Verify 400 when restoring active book"
        }
      ]
    }
  ]
}