{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "health_check_ok",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření dostupnosti API"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření autora"
        },
        {
          "name": "create_author_invalid_data",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba validace při prázdném jménu"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_conflict",
          "type": "error",
          "expected_status": 409,
          "description": "Smazání autora s knihami vrací 409"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření knihy se stock=10"
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní ISBN vrací 409"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření výchozího stránkování"
        },
        {
          "name": "list_books_search_filter",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření vyhledávání knih"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_valid_old_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Sleva na knihu starší 1 roku"
        },
        {
          "name": "apply_discount_new_book_fail",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na novou knihu (letošní rok) zamítnuta"
        },
        {
          "name": "apply_discount_over_limit",
          "type": "error",
          "expected_status": 422,
          "description": "Sleva nad 50 % zamítnuta validací schématu"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_increase",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Přičtení k zásobám"
        },
        {
          "name": "update_stock_negative_insufficient",
          "type": "error",
          "expected_status": 400,
          "description": "Odečtení pod nulu vrací 400"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Přidání validních tagů"
        },
        {
          "name": "add_nonexistent_tag_error",
          "type": "error",
          "expected_status": 404,
          "description": "Neexistující tag vrací 404"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tags_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úspěšné odebrání vazby tagu"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření objednávky"
        },
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Objednávka nad rámec skladu"
        },
        {
          "name": "create_order_duplicate_items",
          "type": "error",
          "expected_status": 400,
          "description": "Duplicitní položky v objednávce"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_status_allowed_transition",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Validní přechod pending->confirmed"
        },
        {
          "name": "update_status_forbidden_transition",
          "type": "error",
          "expected_status": 400,
          "description": "Neplatný přechod stavů"
        },
        {
          "name": "update_status_cancel_restores_stock",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Zrušení objednávky vrací sklad"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_pending_order_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání pending objednávky"
        },
        {
          "name": "delete_confirmed_order_error",
          "type": "error",
          "expected_status": 400,
          "description": "Smazání potvrzené objednávky zamítnuto"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_unique",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření nového tagu"
        },
        {
          "name": "create_tag_duplicate",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicita názvu tagu vrací 409"
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_tag_attached_fail",
          "type": "error",
          "expected_status": 409,
          "description": "Smazání tagu přiřazeného ke knize vrací 409"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Rating mimo rozsah 1-5"
        },
        {
          "name": "create_review_unauthorized_empty_user",
          "type": "error",
          "expected_status": 401,
          "description": "Recenze bez identifikace uživatele vrací 401"
        },
        {
          "name": "create_review_nonexistent_book",
          "type": "error",
          "expected_status": 404,
          "description": "Vložení recenze k neexistující knize vrací 404"
        }
      ]
    }
  ]
}