{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "health_check_ok",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření dostupnosti API."
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření autora."
        },
        {
          "name": "create_author_invalid_data",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba validace při chybějícím jménu."
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_conflict",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat autora s knihami."
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření knihy se stock 10."
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní ISBN vrací 409."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_old_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Sleva na knihu starší 1 roku."
        },
        {
          "name": "apply_discount_new_book_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na novou knihu vrací 400."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_add_positive",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Přičtení k zásobám."
        },
        {
          "name": "update_stock_negative_below_zero",
          "type": "error",
          "expected_status": 400,
          "description": "Odečtení vedoucí k zápornému skladu."
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření nového tagu."
        },
        {
          "name": "create_tag_too_long",
          "type": "edge_case",
          "expected_status": 422,
          "description": "Tag delší než 30 znaků."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Přidání tagů ke knize."
        },
        {
          "name": "add_nonexistent_tag",
          "type": "error",
          "expected_status": 404,
          "description": "Přidání neexistujícího tagu."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tag_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Odebrání existující vazby tagu."
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšná objednávka s odečtem skladu."
        },
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Nedostatečný počet kusů skladem."
        },
        {
          "name": "create_order_duplicate_items",
          "type": "error",
          "expected_status": 400,
          "description": "Stejná kniha 2x v položkách."
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "change_status_valid",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Přechod pending na confirmed."
        },
        {
          "name": "change_status_invalid_transition",
          "type": "error",
          "expected_status": 400,
          "description": "Neplatný stavový přechod."
        },
        {
          "name": "cancel_order_restores_stock",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Zrušení vrátí počet kusů do skladu."
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_pending_order_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání pending objednávky."
        },
        {
          "name": "delete_shipped_order_fail",
          "type": "error",
          "expected_status": 400,
          "description": "Nelze smazat expedovanou objednávku."
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření stránkování v seznamu knih."
        },
        {
          "name": "list_books_search_filter",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrování knih podle textu."
        },
        {
          "name": "list_books_invalid_pagination",
          "type": "edge_case",
          "expected_status": 400,
          "description": "Negativní číslo stránky v parametrech."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_no_reviews",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Vrácení null pokud nejsou recenze."
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_duplicate_category",
          "type": "error",
          "expected_status": 409,
          "description": "Unikátnost názvu kategorie."
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_tag_attached_fail",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat tag přiřazený ke knize."
        },
        {
          "name": "delete_nonexistent_tag",
          "type": "error",
          "expected_status": 404,
          "description": "Pokus o smazání tagu, který neexistuje."
        }
      ]
    }
  ]
}