{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "health_check_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni dostupnosti API"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne vytvoreni autora"
        },
        {
          "name": "create_author_invalid_data",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba validace pri prazdnem jmenu"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_conflict",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat autora s knihami"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne vytvoreni kategorie"
        },
        {
          "name": "create_category_duplicate",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitni nazev kategorie"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni knihy se skladem 10"
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Chyba pri stejnem ISBN"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_book_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Kniha nenalezena"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne pridani recenze"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_empty",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni null hodnoceni pro novou knihu"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_new_book_error",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na knihu mladsí 1 roku"
        },
        {
          "name": "apply_discount_valid",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Sleva na starou knihu"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "increase_stock_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Navyseni skladu o kladnou deltu"
        },
        {
          "name": "decrease_stock_insufficient",
          "type": "error",
          "expected_status": 400,
          "description": "Chyba pri pokusu o zaporny stav skladu"
        }
      ]
    },
    {
      "endpoint": "/tags",
