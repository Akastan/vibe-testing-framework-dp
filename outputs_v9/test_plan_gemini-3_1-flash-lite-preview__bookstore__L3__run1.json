          "expected_status": 409,
          "description": "Nelze smazat tag prirazeny ke knize"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Uspesne pridani tagu ke knize"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tags_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Uspesne odebrani tagu z knihy"
        }
      ]
    },
