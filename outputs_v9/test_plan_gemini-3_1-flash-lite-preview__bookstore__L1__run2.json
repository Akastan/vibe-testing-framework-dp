{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "check_health_status",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření dostupnosti API."
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření autora s platnými údaji."
        },
        {
          "name": "create_author_invalid_data",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba při vytvoření autora bez jména."
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_conflict",
          "type": "error",
          "expected_status": 409,
          "description": "Smazání autora, který má přiřazené knihy."
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_duplicate_name",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní název kategorie vrací 409."
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření knihy s povinnými atributy."
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Vytvoření knihy s již existujícím ISBN."
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření funkčnosti stránkování knih."
        },
        {
          "name": "list_books_invalid_page",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba při zadání stránky < 1."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_book_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Úspěšné smazání existující knihy."
        },
        {
          "name": "delete_book_non_existent",
          "type": "error",
          "expected_status": 404,
          "description": "Pokus o smazání neexistující knihy (Edge case)."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření recenze pro knihu."
        },
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Hodnocení mimo rozsah 1-5."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_empty_reviews",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření vrácení null hodnoty, pokud kniha nemá recenze."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_too_new_book",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na knihu vydanou v aktuálním roce (mladší 1 roku)."
        },
        {
          "name": "apply_discount_invalid_percent",
          "type": "error",
          "expected_status": 422,
          "description": "Sleva vyšší než 50 procent."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_increase",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Navýšení skladu knihy."
        },
        {
          "name": "update_stock_negative_result",
          "type": "error",
          "expected_status": 400,
          "description": "Snížení skladu pod nulu."
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření unikátního tagu."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_to_book_idempotent",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Přidání již existujícího tagu ke knize (ignorováno)."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tags_from_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Odebrání tagů z knihy."
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Objednávka knihy s nedostatkem skladu."
        },
        {
          "name": "create_order_duplicate_book",
          "type": "error",
          "expected_status": 400,
          "description": "Více položek se stejným book_id v objednávce."
        },
        {
          "name": "create_order_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření platné objednávky."
        },
        {
          "name": "create_order_empty_cart",
          "type": "error",
          "expected_status": 422,
          "description": "Pokus o vytvoření objednávky s prázdným seznamem knih (Validace)."
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_orders_filtering_customer",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrování objednávek podle jména zákazníka."
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_confirmed_order_failure",
          "type": "error",
          "expected_status": 400,
          "description": "Pokus o smazání potvrzené objednávky."
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_status_invalid_transition",
          "type": "error",
          "expected_status": 400,
          "description": "Přechod ze stavu delivered do pending."
        },
        {
          "name": "update_status_cancellation_restores_stock",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Zrušení objednávky vrací počet kusů zpět do skladu."
        }
      ]
    },
    {
      "endpoint": "/non_existent_endpoint",
      "method": "GET",
      "test_cases": [
        {
          "name": "check_404_handling",
          "type": "error",
          "expected_status": 404,
          "description": "Ověření, že neexistující endpoint vrací 404."
        }
      ]
    }
  ]
}