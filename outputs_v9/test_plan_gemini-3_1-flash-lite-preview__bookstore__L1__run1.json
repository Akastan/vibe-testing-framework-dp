{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "check_health_status",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření dostupnosti API"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_valid_author",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření nového autora"
        },
        {
          "name": "create_invalid_author_missing_name",
          "type": "error",
          "expected_status": 422,
          "description": "Pokus o vytvoření autora bez jména"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Smazání autora, který má přiřazené knihy"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_with_stock_10",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření knihy s nastaveným stock na 10"
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Pokus o vytvoření knihy s již existujícím ISBN"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_nonexistent_book",
          "type": "error",
          "expected_status": 404,
          "description": "Získání neexistující knihy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_valid_old_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Sleva na knihu starší než 1 rok"
        },
        {
          "name": "apply_discount_new_book_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Pokus o slevu na knihu vydanou v aktuálním roce"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "increment_stock_quantity",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Navýšení skladu pomocí delta hodnoty"
        },
        {
          "name": "negative_stock_result_error",
          "type": "error",
          "expected_status": 400,
          "description": "Pokus o odečtení více zásob, než je k dispozici"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_multiple_tags_to_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Přidání seznamu tagů ke knize"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tag_from_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Odebrání existujícího tagu z vazby knihy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_valid_review",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření recenze k existující knize"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_empty_reviews",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání hodnocení pro knihu bez recenzí"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_duplicate_name",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní název kategorie"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_valid_tag",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření nového tagu"
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_assigned_tag_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Smazání tagu, který je přiřazen ke knize"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Vytvoření objednávky s nedostatkem skladu"
        },
        {
          "name": "create_order_duplicate_book_id",
          "type": "error",
          "expected_status": 400,
          "description": "Objednávka se stejnou knihou v položkách"
        },
        {
          "name": "create_valid_order_reduces_stock",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšná objednávka snižuje sklad"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_shipped_order_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Pokus o smazání objednávky, která již byla odeslána"
        },
        {
          "name": "delete_pending_order_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání pending objednávky vrací sklad"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_status_pending_to_confirmed",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Platný přechod stavu objednávky"
        },
        {
          "name": "update_status_invalid_transition",
          "type": "error",
          "expected_status": 400,
          "description": "Nepovolený přechod mezi stavy objednávky"
        },
        {
          "name": "cancel_order_restores_stock",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Zrušení objednávky vrací sklad"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Stránkování výpisu knih"
        },
        {
          "name": "list_books_filter_by_price",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrace knih podle ceny"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "GET",
      "test_cases": [
        {
          "name": "filter_orders_by_customer_name",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrace objednávek dle jména (case-insensitive)"
        },
        {
          "name": "list_orders_invalid_page",
          "type": "error",
          "expected_status": 422,
          "description": "Neplatná hodnota stránky pro list orders"
        }
      ]
    }
  ]
}