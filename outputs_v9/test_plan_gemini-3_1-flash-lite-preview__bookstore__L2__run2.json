{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "health_check_ok",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni dostupnosti API"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne vytvoreni autora"
        },
        {
          "name": "create_author_invalid_data",
          "type": "error",
          "expected_status": 422,
          "description": "Pokus o vytvoreni autora bez jmena"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Smazani autora s prirazenymi knihami vrací 409"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni knihy se stock=10"
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Pokus o vytvoreni knihy se stejnym ISBN"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_book_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Ziskani neexistujici knihy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni validni recenze"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_null_for_new_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni ze kniha bez recenzi vraci null"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_on_new_book_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na knihu vydanou v aktualnim roce"
        },
        {
          "name": "apply_discount_on_old_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Sleva na knihu vydanou pred vice nez rokem"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_increase",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Pridani mnozstvi na sklad"
        },
        {
          "name": "update_stock_insufficient",
          "type": "error",
          "expected_status": 400,
          "description": "Odecet skladu pod nulu"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni noveho tagu"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_to_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Pridani listu tagu ke knize"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tags_from_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Odebrani existujicich tagu z knihy"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne vytvoreni objednavky"
        },
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Vytvoreni objednavky nad kapacitu skladu"
        },
        {
          "name": "create_order_duplicate_book_id",
          "type": "error",
          "expected_status": 400,
          "description": "Dva stejne book_id v jedne objednavce"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "change_status_pending_to_confirmed",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Validni prechod stavu objednavky"
        },
        {
          "name": "change_status_invalid_transition",
          "type": "error",
          "expected_status": 400,
          "description": "Pokus o prechod z delivered na pending"
        },
        {
          "name": "cancel_order_restores_stock",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni vraceni skladu pri zruseni"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_pending_order_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazani pending objednavky"
        },
        {
          "name": "delete_shipped_order_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Nelze smazat odeslanou objednavku"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Test strankovani knih"
        },
        {
          "name": "list_books_price_filter",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrovani knih dle ceny"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_unique_name",
          "type": "edge_case",
          "expected_status": 201,
          "description": "Vytvoreni kategorie"
        },
        {
          "name": "create_category_duplicate_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitni jmeno kategorie"
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_assigned_tag_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat tag prirazeny ke knize"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_reviews_malformed_query_params",
          "type": "error",
          "expected_status": 400,
          "description": "Validace spatne formatovanych query parametru u strankovani recenzi"
        }
      ]
    }
  ]
}