{
  "test_plan": [
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne vytvoreni autora"
        },
        {
          "name": "create_author_invalid_name",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba pri prazdnem jmenu autora"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_conflict",
          "type": "error",
          "expected_status": 409,
          "description": "Smazani autora, ktery ma prirazene knihy"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_duplicate_name",
          "type": "error",
          "expected_status": 409,
          "description": "Pokus o vytvoreni duplicitni kategorie"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni knihy se stock 10"
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Pokus o vytvoreni knihy s existujicim ISBN"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_nonexistent_book",
          "type": "error",
          "expected_status": 404,
          "description": "Ziskani neexistujici knihy vraci 404"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Validace ratingu mimo rozsah 1-5"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_null_for_no_reviews",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni null prumerneho hodnoceni"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_new_book_fail",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na knihu mladsi nez 1 rok"
        },
        {
          "name": "apply_discount_valid",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Uspesna sleva na starou knihu"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "add_stock_positive_delta",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Pridani skladu (10+5=15)"
        },
        {
          "name": "remove_stock_insufficient",
          "type": "error",
          "expected_status": 400,
          "description": "Odebrani vetsiho poctu nez je sklad"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_unique",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne vytvoreni tagu"
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_assigned_tag_fail",
          "type": "error",
          "expected_status": 409,
          "description": "Smazani tagu prirazeneho ke knize"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Pridani tagu ke knize"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tags_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Odebrani tagu z knihy"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesna objednavka"
        },
        {
          "name": "create_order_duplicate_items",
          "type": "error",
          "expected_status": 400,
          "description": "Duplicate book_id v polozkach"
        },
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Nedostatecny sklad pri objednavce"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_order_shipped_fail",
          "type": "error",
          "expected_status": 400,
          "description": "Smazani odeslane objednavky"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "transition_pending_to_confirmed",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Povoleny prechod stavu"
        },
        {
          "name": "transition_invalid",
          "type": "error",
          "expected_status": 400,
          "description": "Zakazany prechod stavu"
        },
        {
          "name": "cancel_order_restores_stock",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Zruseni vrati sklad"
        }
      ]
    },
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "health_check_ok",
          "type": "happy_path",
          "expected_status": 200,
          "description": "System health check"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Test strankovani knih"
        },
        {
          "name": "list_books_invalid_page",
          "type": "error",
          "expected_status": 422,
          "description": "Page < 1"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_orders_filtering",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrace podle jmena"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_authors_default",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Vypis autoru"
        },
        {
          "name": "list_authors_malformed_query_param",
          "type": "error",
          "expected_status": 400,
          "description": "Chyba pri predani neplatneho typu query parametru (např. string místo int)"
        }
      ]
    }
  ]
}