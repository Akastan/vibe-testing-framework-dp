{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "health_check_ok",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření dostupnosti API."
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření autora s validními daty."
        },
        {
          "name": "create_author_invalid_data",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoření autora bez povinného jména."
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření knihy se stock 10."
        },
        {
          "name": "create_book_invalid_year",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoření knihy s rokem mimo rozsah 1000-2026."
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření stránkování knih."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_book_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Získání neexistující knihy."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_new_book_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na knihu vydanou v aktuálním roce."
        },
        {
          "name": "apply_discount_valid",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Sleva na knihu starší než 1 rok."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "increase_stock_valid",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Navýšení skladu pomocí delta hodnoty."
        },
        {
          "name": "decrease_stock_insufficient",
          "type": "error",
          "expected_status": 400,
          "description": "Odečtení skladu pod nulu."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření recenze k existující knize."
        },
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Recenze s hodnocením 6."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_no_reviews",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Kniha bez recenzí vrací null."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_to_book_valid",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úspěšné přidání tagů."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tags_from_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Odebrání tagu z knihy."
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření objednávky odečte sklad."
        },
        {
          "name": "create_order_duplicate_book",
          "type": "error",
          "expected_status": 400,
          "description": "Stejná kniha 2x v objednávce."
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_status_pending_to_confirmed",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Validní přechod stavu."
        },
        {
          "name": "update_status_illegal_transition",
          "type": "error",
          "expected_status": 400,
          "description": "Pokus o přechod mimo automat."
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_duplicate",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní název kategorie."
        }
      ]
    },
    {
      "endpoint": "/categories/{category_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_category_with_books",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat kategorii s knihami."
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření nového tagu."
        },
        {
          "name": "create_tag_too_long",
          "type": "error",
          "expected_status": 422,
          "description": "Tag delší než 30 znaků."
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_tag_in_use",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat tag přiřazený ke knize."
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_orders_filter_customer",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrování dle jména zákazníka."
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_shipped_order_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Nelze smazat objednávku v terminálním stavu."
        },
        {
          "name": "delete_pending_order_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání pending objednávky vrací sklad."
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_books_invalid_pagination_params",
          "type": "error",
          "expected_status": 400,
          "description": "Zadání záporné hodnoty pro stránkování (page/size)."
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_malformed_json",
          "type": "error",
          "expected_status": 400,
          "description": "Odeslání syntakticky nevalidního JSON těla."
        }
      ]
    }
  ]
}