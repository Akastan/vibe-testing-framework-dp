{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "check_health_status",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření dostupnosti API"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření autora"
        },
        {
          "name": "create_author_invalid_data",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba při chybějícím povinném jméně"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_conflict",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat autora s existujícími knihami"
        },
        {
          "name": "delete_nonexistent_author",
          "type": "error",
          "expected_status": 404,
          "description": "Smazání neexistujícího autora vrací 404"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření kategorie"
        },
        {
          "name": "create_duplicate_category_conflict",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní název kategorie vrací 409"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření knihy (stock nastaven na 10)"
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní ISBN vrací 409"
        },
        {
          "name": "create_book_invalid_author",
          "type": "error",
          "expected_status": 404,
          "description": "Neexistující autor vrací 404"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření stránkování knih"
        },
        {
          "name": "list_books_filter_by_price",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrování knih podle ceny"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_book_detail",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Načtení detailu knihy včetně tagů"
        },
        {
          "name": "get_nonexistent_book",
          "type": "error",
          "expected_status": 404,
          "description": "Dotaz na neexistující knihu vrací 404"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření recenze"
        },
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Hodnocení mimo rozsah 1-5"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_no_reviews",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření null hodnoty při chybějících recenzích"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_old_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Sleva na knihu starší 1 roku"
        },
        {
          "name": "apply_discount_new_book_fail",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na novou knihu vrací 400"
        },
        {
          "name": "apply_discount_over_limit",
          "type": "error",
          "expected_status": 422,
          "description": "Sleva nad 50% vrací 422"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "increase_stock_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Přičtení skladu"
        },
        {
          "name": "decrease_stock_negative_fail",
          "type": "error",
          "expected_status": 400,
          "description": "Sklad nesmí být záporný"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření tagu"
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_tag_assigned_to_book_conflict",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat tag přiřazený ke knize"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_idempotency",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Přidání stejných tagů ignoruje duplicity"
        },
        {
          "name": "add_nonexistent_tag_fail",
          "type": "error",
          "expected_status": 404,
          "description": "Neexistující tag vrací 404"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tags_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úspěšné odstranění tagů"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření objednávky"
        },
        {
          "name": "create_order_duplicate_book_id",
          "type": "error",
          "expected_status": 400,
          "description": "Duplicitní book_id v objednávce vrací 400"
        },
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Nedostatek skladu vrací 400"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_status_transition_valid",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Povolený přechod stavu objednávky"
        },
        {
          "name": "update_status_transition_invalid",
          "type": "error",
          "expected_status": 400,
          "description": "Nepovolený přechod stavu vrací 400"
        },
        {
          "name": "cancel_order_restores_stock",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Zrušení objednávky vrátí sklad"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_pending_order_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání pending objednávky"
        },
        {
          "name": "delete_shipped_order_fail",
          "type": "error",
          "expected_status": 400,
          "description": "Smazání shipped objednávky vrací 400"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_orders_filtering",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrování objednávek podle zákazníka"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_authors_empty",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Seznam autorů v prázdné databázi"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_categories_all",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Seznam všech kategorií"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_tags_all",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Seznam všech tagů"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úspěšná aktualizace údajů knihy"
        },
        {
          "name": "update_book_invalid_isbn_format",
          "type": "error",
          "expected_status": 422,
          "description": "Nevalidní formát ISBN"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_author_detail",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání detailu existujícího autora"
        }
      ]
    },
    {
      "endpoint": "/categories/{category_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_category_detail",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání detailu existující kategorie"
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_tag_detail",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání detailu existujícího tagu"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_author_name_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úspěšná aktualizace jména autora"
        }
      ]
    },
    {
      "endpoint": "/categories/{category_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_category_description",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Aktualizace popisu kategorie"
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_tag_name_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úspěšná aktualizace názvu tagu"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_reviews_for_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Seznam recenzí pro danou knihu"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_book_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Úspěšné smazání knihy"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_without_books",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání autora bez knih"
        }
      ]
    }
  ]
}