{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "check_health_status",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření dostupnosti API"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření autora"
        },
        {
          "name": "create_author_invalid_data",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba při odeslání prázdného jména"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Smazání autora s přiřazenými knihami vrací 409"
        },
        {
          "name": "delete_nonexistent_author",
          "type": "error",
          "expected_status": 404,
          "description": "Smazání neexistujícího autora vrací 404"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_duplicate_name",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní název kategorie vrací 409"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_with_default_stock",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření knihy s nastaveným stock=10"
        },
        {
          "name": "create_book_invalid_isbn",
          "type": "error",
          "expected_status": 422,
          "description": "ISBN mimo rozsah 10-13 znaků"
        },
        {
          "name": "create_book_nonexistent_author",
          "type": "error",
          "expected_status": 404,
          "description": "Vytvoření knihy s neexistujícím autorem"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření stránkování knih"
        },
        {
          "name": "list_books_price_filter",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrování knih podle min_price"
        },
        {
          "name": "list_books_invalid_query_params",
          "type": "error",
          "expected_status": 400,
          "description": "Neznámý parametr v query stringu vrací 400"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_book_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Získání neexistující knihy vrací 404"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "add_stock_positive_delta",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Navýšení skladu o N"
        },
        {
          "name": "decrease_stock_negative_delta",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Snížení skladu o N"
        },
        {
          "name": "reduce_stock_below_zero",
          "type": "error",
          "expected_status": 400,
          "description": "Výsledný záporný sklad vrací 400"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_old_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Sleva na knihu starší než 1 rok"
        },
        {
          "name": "apply_discount_new_book_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na novou knihu vrací 400"
        },
        {
          "name": "discount_exceeding_limit",
          "type": "error",
          "expected_status": 422,
          "description": "Sleva > 50% vrací 422"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Přidání platné recenze"
        },
        {
          "name": "create_review_out_of_range",
          "type": "error",
          "expected_status": 422,
          "description": "Rating mimo rozsah 1-5"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_no_reviews",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Průměrné hodnocení bez recenzí je null"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_to_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Přidání tagů ke knize"
        },
        {
          "name": "add_nonexistent_tag",
          "type": "error",
          "expected_status": 404,
          "description": "Přidání neexistujícího tagu"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tag_from_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Odebrání tagu z knihy"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Objednávka převyšující sklad"
        },
        {
          "name": "create_order_duplicate_items",
          "type": "error",
          "expected_status": 400,
          "description": "Duplicitní položka v objednávce"
        },
        {
          "name": "create_order_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření objednávky"
        },
        {
          "name": "create_order_malformed_json",
          "type": "error",
          "expected_status": 400,
          "description": "Chybný formát JSON v request body"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_status_pending_to_confirmed",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Platný přechod stavu"
        },
        {
          "name": "update_status_invalid_transition",
          "type": "error",
          "expected_status": 400,
          "description": "Nepovolený přechod (např. delivered -> pending)"
        },
        {
          "name": "cancel_order_restores_stock",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Zrušení objednávky vrací kusy do skladu"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_shipped_order_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Smazání objednávky, která není pending/cancelled"
        },
        {
          "name": "delete_pending_order_returns_stock",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání pending objednávky vrací sklad"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_duplicate_tag_name",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní název tagu vrací 409"
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_tag_in_use_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat tag, který je přiřazen ke knize"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_book_invalid_year",
          "type": "error",
          "expected_status": 422,
          "description": "Rok vydání mimo limit"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_orders_filtering",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrování objednávek podle zákazníka"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_author_data",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání detailu autora"
        }
      ]
    },
    {
      "endpoint": "/categories/{category_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_category_data",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání detailu kategorie"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_book_cascade_reviews",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání knihy smaže i její recenze"
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_tag_data",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úprava názvu tagu"
        },
        {
          "name": "update_tag_empty_name",
          "type": "error",
          "expected_status": 422,
          "description": "Prázdný název tagu při update vrací 422"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_order_detail",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání detailu objednávky"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_reviews_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Seznam všech recenzí knihy"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_authors_empty",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Výpis autorů při prázdné databázi"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_categories_full",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Výpis všech kategorií"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_book_stock_nullable",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Částečná aktualizace knihy"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_all_tags",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Výpis všech dostupných tagů"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_author_name_length",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba při příliš dlouhém jméně"
        }
      ]
    }
  ]
}