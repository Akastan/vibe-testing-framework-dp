          "expected_status": 400,
          "description": "Duplicitní ID knihy v jedné objednávce."
        },
        {
          "name": "create_order_empty_items_array",
          "type": "error",
          "expected_status": 422,
          "description": "Prázdné pole položek není validní."
        }
