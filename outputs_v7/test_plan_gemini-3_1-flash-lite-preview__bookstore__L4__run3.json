          "description": "Přidání tagů ke knize."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tags_valid",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Odebrání existující vazby tagu."
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_full_valid",
