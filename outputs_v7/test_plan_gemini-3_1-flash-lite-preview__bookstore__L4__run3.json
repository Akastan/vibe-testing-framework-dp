          "expected_status": 200,
          "description": "Ověření dostupnosti API."
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření autora s validními údaji."
        },
        {
          "name": "create_author_invalid_name_length",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba při vytvoření autora s prázdným jménem."
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_authors_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření stránkování u výpisu autorů."
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_author_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úspěšná aktualizace údajů autora."
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_valid",
