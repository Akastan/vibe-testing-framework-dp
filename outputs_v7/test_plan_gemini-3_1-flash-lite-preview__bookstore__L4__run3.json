    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_pending_order_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání pending objednávky."
        },
        {
          "name": "delete_delivered_order_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Nelze smazat doručenou objednávku."
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_unused",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání autora bez knih."
        }
      ]
    },
    {
      "endpoint": "/categories/{category_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_category_unused",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání prázdné kategorie."
        },
        {
          "name": "delete_category_with_books_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Smazání kategorie, která obsahuje knihy."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_book_success",
          "type": "happy_path",
