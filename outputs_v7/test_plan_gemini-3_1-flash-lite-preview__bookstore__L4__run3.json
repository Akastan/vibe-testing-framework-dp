          "description": "Vytvoření kategorie."
        },
        {
          "name": "create_category_duplicate",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní název kategorie vrací 409."
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření knihy (stock nastaven na 10)."
        },
        {
          "name": "create_book_missing_author",
          "type": "error",
          "expected_status": 404,
          "description": "Vytvoření knihy s neexistujícím autorem."
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_search_filter",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrování knih podle vyhledávacího dotazu."
        },
        {
          "name": "list_books_invalid_page_number",
          "type": "error",
          "expected_status": 422,
          "description": "Předání záporné stránky do filtru."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_book_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Nalezení knihy vrací 404."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_valid",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření recenze."
        },
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Rating mimo rozsah 1-5."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_no_reviews",
          "type": "edge_case",
          "expected_status": 200,
          "description": "Kniha bez recenzí vrací null průměr."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_new_book_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na knihu vydanou letos (aktuální rok) není povolena."
        },
        {
          "name": "apply_discount_valid_limit",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Maximální sleva 50 %."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_increase",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Přičtení k existujícímu skladu."
        },
        {
          "name": "update_stock_negative_excessive",
          "type": "error",
          "expected_status": 400,
          "description": "Odečtení více než je na skladě."
        }
      ]
    },
    {
      "endpoint": "/tags",
