{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "check_health_status",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření dostupnosti API"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_valid_author",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření nového autora"
        },
        {
          "name": "create_author_invalid_data",
          "type": "error",
          "expected_status": 422,
          "description": "Vytvoření autora s nevalidním jménem"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_error",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat autora s knihami"
        },
        {
          "name": "delete_nonexistent_author",
          "type": "error",
          "expected_status": 404,
          "description": "Smazání neexistujícího autora"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_unique_category",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření nové kategorie"
        },
        {
          "name": "create_duplicate_category_error",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní název kategorie"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_with_stock_10",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření knihy s nastaveným stock na 10"
        },
        {
          "name": "create_book_with_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní ISBN knihy"
        },
        {
          "name": "create_book_nonexistent_author",
          "type": "error",
          "expected_status": 404,
          "description": "Vytvoření knihy s chybějícím autorem"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření stránkování knih"
        },
        {
          "name": "search_books_by_title",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Vyhledávání knih podle názvu"
        },
        {
          "name": "filter_books_by_price",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrace knih podle ceny"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_book_title",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úprava názvu knihy"
        },
        {
          "name": "update_book_invalid_year",
          "type": "error",
          "expected_status": 422,
          "description": "Úprava roku vydání mimo rozsah"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_happy_path",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření platné recenze"
        },
        {
          "name": "create_review_out_of_range",
          "type": "error",
          "expected_status": 422,
          "description": "Recenze s hodnocením 6"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_no_reviews",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Průměrné hodnocení bez recenzí vrací null"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_valid_year",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Sleva na knihu starší 1 roku"
        },
        {
          "name": "apply_discount_new_book_error",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na novou knihu z aktuálního roku"
        },
        {
          "name": "apply_discount_above_limit",
          "type": "error",
          "expected_status": 422,
          "description": "Sleva vyšší než 50 procent"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "add_stock_to_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Navýšení skladu o 5 kusů"
        },
        {
          "name": "remove_stock_below_zero_error",
          "type": "error",
          "expected_status": 400,
          "description": "Odečtení více kusů než je skladem"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_happy_path",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření tagu"
        },
        {
          "name": "create_duplicate_tag_error",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicita názvu tagu"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_to_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Přidání existujícího tagu ke knize"
        },
        {
          "name": "add_nonexistent_tag_error",
          "type": "error",
          "expected_status": 404,
          "description": "Přidání neexistujícího ID tagu"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tags_from_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Odebrání tagu z knihy"
        }
      ]
    },
