{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "check_health_status",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření dostupnosti API"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_valid_author",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření autora"
        },
        {
          "name": "create_author_invalid_data",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba při chybějícím jméně"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_error",
          "type": "error",
          "expected_status": 409,
          "description": "Smazání autora s knihami zakázáno"
        },
        {
          "name": "delete_nonexistent_author",
          "type": "error",
          "expected_status": 404,
          "description": "Smazání neexistujícího autora"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření knihy"
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní ISBN vrací 409"
        },
        {
          "name": "create_book_invalid_year",
          "type": "error",
          "expected_status": 422,
          "description": "Rok vydání mimo rozsah"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_default_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Výchozí stránkování knih"
        },
        {
          "name": "filter_books_by_price",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrování knih podle ceny"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_book_details",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání detailu existující knihy"
        },
        {
          "name": "get_nonexistent_book",
          "type": "error",
          "expected_status": 404,
          "description": "Získání neexistující knihy"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné přidání recenze"
        },
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Rating mimo rozsah 1-5"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_no_reviews",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Rating null pro knihy bez recenzí"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_old_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Sleva pro knihu starší než 1 rok"
        },
        {
          "name": "apply_discount_new_book_error",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva nepovolena pro knihy mladší 1 roku"
        },
        {
          "name": "discount_exceeds_limit",
          "type": "error",
          "expected_status": 422,
          "description": "Sleva nad 50 procent je nevalidní"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "increment_stock_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úspěšné navýšení skladu"
        },
        {
          "name": "decrement_stock_insufficient",
          "type": "error",
          "expected_status": 400,
          "description": "Záporný sklad po odečtení"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření tagu"
        },
        {
          "name": "create_duplicate_tag_error",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní název tagu vrací 409"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_to_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úspěšné přidání existujících tagů"
        },
        {
          "name": "add_nonexistent_tag_error",
          "type": "error",
          "expected_status": 404,
          "description": "Přidání neexistujícího tagu"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tags_from_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Odebrání tagů z knihy"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Nelze vytvořit objednávku bez skladu"
        },
        {
          "name": "create_order_duplicate_items",
          "type": "error",
          "expected_status": 400,
          "description": "Duplicitní kniha v objednávce"
        },
        {
          "name": "create_order_valid_items",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšná objednávka"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "transition_pending_to_confirmed",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Validní přechod stavu objednávky"
        },
        {
          "name": "transition_invalid_order_status",
          "type": "error",
          "expected_status": 400,
          "description": "Neplatný přechod stavu objednávky"
        },
        {
          "name": "cancel_order_returns_stock",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Zrušení objednávky vrací sklad"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_pending_order_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání pending objednávky"
        },
        {
          "name": "delete_delivered_order_error",
          "type": "error",
          "expected_status": 400,
          "description": "Nelze smazat doručenou objednávku"
        }
      ]
    },
    {
