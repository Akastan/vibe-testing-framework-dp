{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "check_health_status",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Overeni ze API bezi"
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne vytvoreni autora"
        },
        {
          "name": "create_author_invalid_data",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba pri chybejicim jmene"
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_with_books_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Smazani autora s knihami vrací 409"
        },
        {
          "name": "delete_nonexistent_author",
          "type": "error",
          "expected_status": 404,
          "description": "Smazani neexistujiciho autora"
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Uspesne vytvoreni kategorie"
        },
        {
          "name": "create_duplicate_category_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní název kategorie"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni knihy se stock 10"
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicitní ISBN u knihy"
        },
        {
          "name": "create_book_missing_relation",
          "type": "error",
          "expected_status": 404,
          "description": "Nexistujici autor"
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Stránkování knih"
        },
        {
          "name": "filter_books_by_price",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrace podle ceny"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_book_title",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Aktualizace nazvu knihy"
        },
        {
          "name": "update_book_invalid_year",
          "type": "error",
          "expected_status": 422,
          "description": "Neplatný rok vydání"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Validni recenze"
        },
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Rating mimo rozsah 1-5"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_no_reviews",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Prumer null pro knihu bez recenzi"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_old_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Sleva na starou knihu"
        },
        {
          "name": "apply_discount_new_book_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Sleva na knihu mladsi 1 roku"
        },
        {
          "name": "apply_discount_exceed_limit",
          "type": "error",
          "expected_status": 422,
          "description": "Sleva nad 50 procent"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "increase_stock_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Navyseni skladu"
        },
        {
          "name": "decrease_stock_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Snížení skladu"
        },
        {
          "name": "decrease_stock_below_zero_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Záporný zůstatek skladu"
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni tagu"
        },
        {
          "name": "create_duplicate_tag_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicita tagu"
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_assigned_tag_fails",
          "type": "error",
          "expected_status": 409,
          "description": "Smazani tagu prirazeneho ke knize"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_to_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Pridani tagu"
        },
        {
          "name": "add_nonexistent_tag_fails",
          "type": "error",
          "expected_status": 404,
          "description": "Tag id neexistuje"
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tags_from_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Odebrani tagu"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoreni objednavky"
        },
        {
          "name": "create_order_insufficient_stock",
          "type": "error",
          "expected_status": 400,
          "description": "Nedostatek skladu"
        },
        {
          "name": "create_order_duplicate_items",
          "type": "error",
          "expected_status": 400,
          "description": "Duplicita knihy v objednavce"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "transition_pending_to_confirmed",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Validni prechod stavu"
        },
        {
          "name": "transition_invalid_state",
          "type": "error",
          "expected_status": 400,
          "description": "Nepovoleny prechod"
        },
        {
          "name": "cancel_restores_stock",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Storno vraci sklad"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_pending_order_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazani pending objednavky"
        },
        {
          "name": "delete_delivered_order_fails",
          "type": "error",
          "expected_status": 400,
          "description": "Smazani dorucene objednavky"
        }
      ]
    },
    {
      "endpoint": "/authors/9999",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_nonexistent_author",
          "type": "error",
          "expected_status": 404,
          "description": "Autora nelze najit"
        },
        {
          "name": "get_nonexistent_category",
          "type": "error",
          "expected_status": 404,
          "description": "Kategorii nelze najit"
        },
        {
          "name": "get_nonexistent_book",
          "type": "error",
          "expected_status": 404,
          "description": "Knihu nelze najit"
        },
        {
          "name": "get_nonexistent_order",
          "type": "error",
          "expected_status": 404,
          "description": "Objednavku nelze najit"
        },
        {
          "name": "get_nonexistent_tag",
          "type": "error",
          "expected_status": 404,
          "description": "Tag nelze najit"
        },
        {
          "name": "update_nonexistent_book",
          "type": "error",
          "expected_status": 404,
          "description": "Update neexistujici knihy"
        },
        {
          "name": "delete_nonexistent_order",
          "type": "error",
          "expected_status": 404,
          "description": "Delete neexistujici order"
        },
        {
          "name": "add_tags_nonexistent_book",
          "type": "error",
          "expected_status": 404,
          "description": "Tagy k neexistujici knize"
        },
        {
          "name": "apply_discount_nonexistent_book",
          "type": "error",
          "expected_status": 404,
          "description": "Sleva na neexistujici knihu"
        },
        {
          "name": "get_rating_nonexistent_book",
          "type": "error",
          "expected_status": 404,
          "description": "Rating neexistujici knihy"
        },
        {
          "name": "update_stock_nonexistent_book",
          "type": "error",
          "expected_status": 404,
          "description": "Stock neexistujici knihy"
        },
        {
          "name": "patch_order_status_nonexistent",
          "type": "error",
          "expected_status": 404,
          "description": "Patch stavu neexistujiciho orderu"
        },
        {
          "name": "update_tag_nonexistent",
          "type": "error",
          "expected_status": 404,
          "description": "Update neexistujiciho tagu"
        }
      ]
