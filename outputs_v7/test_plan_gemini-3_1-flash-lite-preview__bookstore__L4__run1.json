{
  "test_plan": [
    {
      "endpoint": "/health",
      "method": "GET",
      "test_cases": [
        {
          "name": "health_check_returns_ok",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Ověření, že API vrací 200 OK pro health check."
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_author_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření autora."
        },
        {
          "name": "create_author_invalid_data",
          "type": "error",
          "expected_status": 422,
          "description": "Chyba při vytvoření autora bez jména."
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_author_by_id_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání detailu existujícího autora."
        },
        {
          "name": "get_author_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Pokus o získání neexistujícího autora."
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_category_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření kategorie."
        },
        {
          "name": "create_category_duplicate_name",
          "type": "error",
          "expected_status": 409,
          "description": "Pokus o vytvoření kategorie se stejným názvem."
        }
      ]
    },
    {
      "endpoint": "/categories/{category_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_category_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání prázdné kategorie."
        },
        {
          "name": "delete_category_with_books_conflict",
          "type": "error",
          "expected_status": 409,
          "description": "Nelze smazat kategorii, která má přiřazené knihy."
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_book_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření knihy."
        },
        {
          "name": "create_book_invalid_isbn_length",
          "type": "error",
          "expected_status": 422,
          "description": "ISBN mimo rozsah 10-13 znaků vrací 422."
        },
        {
          "name": "create_book_duplicate_isbn",
          "type": "error",
          "expected_status": 409,
          "description": "Duplicate ISBN vrací 409."
        }
      ]
    },
    {
      "endpoint": "/books",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_books_pagination",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Výpis knih s použitím stránkování."
        },
        {
          "name": "list_books_filter_by_price",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrace knih podle ceny."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_book_not_found",
          "type": "error",
          "expected_status": 404,
          "description": "Neexistující kniha."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/reviews",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_review_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné přidání recenze."
        },
        {
          "name": "create_review_invalid_rating",
          "type": "error",
          "expected_status": 422,
          "description": "Hodnocení mimo rozsah 1-5."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/rating",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_rating_empty_book",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Kniha bez recenzí vrací null average."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/discount",
      "method": "POST",
      "test_cases": [
        {
          "name": "apply_discount_old_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Sleva na knihu starší 1 roku."
        },
        {
          "name": "apply_discount_new_book_fails",
          "type": "edge_case",
          "expected_status": 400,
          "description": "Sleva na novou knihu (<1 rok) musí selhat."
        },
        {
          "name": "apply_discount_above_limit",
          "type": "error",
          "expected_status": 422,
          "description": "Sleva nad 50 % je nevalidní vstup."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/stock",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "update_stock_increase",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Navýšení skladu (delta)."
        },
        {
          "name": "update_stock_decrease_invalid",
          "type": "edge_case",
          "expected_status": 400,
          "description": "Snížení skladu pod nulu."
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_tag_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Úspěšné vytvoření tagu."
        },
        {
          "name": "create_tag_too_long",
          "type": "error",
          "expected_status": 422,
          "description": "Název tagu delší než 30 znaků."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "POST",
      "test_cases": [
        {
          "name": "add_tags_to_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Přidání validních tagů ke knize."
        },
        {
          "name": "add_nonexistent_tag",
          "type": "error",
          "expected_status": 404,
          "description": "Přidání tagu, který neexistuje."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}/tags",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "remove_tags_from_book_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úspěšné odstranění tagu."
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření objednávky s knihami, které mají dostatečný sklad."
        },
        {
          "name": "create_order_insufficient_stock",
          "type": "edge_case",
          "expected_status": 400,
          "description": "Objednávka selže, pokud není dostatek skladu."
        },
        {
          "name": "create_order_duplicate_book_id",
          "type": "error",
          "expected_status": 400,
          "description": "Stejná kniha v jednom seznamu položek."
        },
        {
          "name": "create_order_no_items",
          "type": "error",
          "expected_status": 422,
          "description": "Objednávka bez položek."
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_orders_filter_status",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Filtrování objednávek podle stavu."
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
      "method": "PATCH",
      "test_cases": [
        {
          "name": "order_transition_pending_to_confirmed",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Validní přechod pending -> confirmed."
        },
        {
          "name": "order_transition_invalid",
          "type": "error",
          "expected_status": 400,
          "description": "Nepovolený přechod (např. pending -> delivered)."
        },
        {
          "name": "order_cancel_restores_stock",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Při zrušení objednávky se vrací sklad."
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_pending_order_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání pending objednávky."
        },
        {
          "name": "delete_shipped_order_error",
          "type": "error",
          "expected_status": 400,
          "description": "Nelze smazat odeslanou objednávku."
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_author_data",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úspěšná aktualizace autora."
        }
      ]
    },
    {
      "endpoint": "/categories/{category_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_category_data",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Aktualizace názvu kategorie."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_book_data",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Úspěšná úprava údajů knihy."
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "PUT",
      "test_cases": [
        {
          "name": "update_tag_data",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Aktualizace názvu tagu."
        }
      ]
    },
    {
      "endpoint": "/authors/{author_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_author_without_books",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání autora bez knih."
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_tag_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání detailu tagu."
        }
      ]
    },
    {
      "endpoint": "/books/{book_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_book_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání knihy."
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}",
      "method": "GET",
      "test_cases": [
        {
          "name": "get_order_success",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Získání detailu objednávky."
        }
      ]
    },
    {
      "endpoint": "/authors",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_authors_default",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Výpis autorů."
        }
      ]
    },
    {
      "endpoint": "/categories",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_categories_all",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Výpis kategorií."
        }
      ]
    },
    {
      "endpoint": "/tags",
      "method": "GET",
      "test_cases": [
        {
          "name": "list_tags_all",
          "type": "happy_path",
          "expected_status": 200,
          "description": "Výpis tagů."
        }
      ]
    },
    {
      "endpoint": "/tags/{tag_id}",
      "method": "DELETE",
      "test_cases": [
        {
          "name": "delete_tag_success",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání tagu, který není přiřazen ke knize."
        }
      ]
    }
  ]
}