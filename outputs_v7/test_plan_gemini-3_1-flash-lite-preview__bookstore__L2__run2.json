          "description": "Odebrání vazby tagu od knihy"
        }
      ]
    },
    {
      "endpoint": "/orders",
      "method": "POST",
      "test_cases": [
        {
          "name": "create_order_success",
          "type": "happy_path",
          "expected_status": 201,
          "description": "Vytvoření objednávky (stock 10 -> 9)"
        },
        {
          "name": "order_duplicate_book_id_error",
          "type": "error",
          "expected_status": 400,
          "description": "Nelze mít stejnou knihu 2x v jedné objednávce"
        }
      ]
    },
    {
      "endpoint": "/orders/{order_id}/status",
