      "test_cases": [
        {
          "name": "delete_pending_order_returns_stock",
          "type": "happy_path",
          "expected_status": 204,
          "description": "Smazání pending objednávky vrací sklad"
        },
        {
          "name": "delete_confirmed_order_error",
          "type": "error",
